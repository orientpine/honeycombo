---
// biome-ignore lint/correctness/noUnusedImports: Astro frontmatter imports are used in template
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="트렌딩 플레이리스트 — HoneyCombo" description="커뮤니티가 가장 좋아하는 기술 기사 플레이리스트">
  <section class="page-shell trending-page" data-trending-page>
    <header class="page-header">
      <h1 class="page-title">🔥 트렌딩 플레이리스트</h1>
      <p class="page-description">커뮤니티가 좋아하는 플레이리스트</p>
    </header>

    <div class="trending-summary" id="trending-summary">
      <p>총 0개의 공개 플레이리스트</p>
      <p>불러오는 중...</p>
    </div>

    <section class="grid grid-3 trending-grid" id="trending-grid" aria-live="polite">
      <article class="card playlist-card skeleton-card">
        <div class="playlist-header">
          <span class="skeleton-line skeleton-title"></span>
          <span class="playlist-count skeleton-count"></span>
        </div>
        <div class="skeleton-line skeleton-text"></div>
        <div class="skeleton-line skeleton-text short"></div>
        <div class="playlist-footer">
          <span class="playlist-curator">
            <span class="skeleton-avatar"></span>
            <span class="skeleton-line skeleton-author-line"></span>
          </span>
          <span class="trending-stats">
            <span class="rank-badge skeleton-box"></span>
            <span class="skeleton-line skeleton-like-count"></span>
            <span class="btn like-button skeleton-button"></span>
          </span>
        </div>
      </article>
      <article class="card playlist-card skeleton-card">
        <div class="playlist-header">
          <span class="skeleton-line skeleton-title"></span>
          <span class="playlist-count skeleton-count"></span>
        </div>
        <div class="skeleton-line skeleton-text"></div>
        <div class="skeleton-line skeleton-text short"></div>
        <div class="playlist-footer">
          <span class="playlist-curator">
            <span class="skeleton-avatar"></span>
            <span class="skeleton-line skeleton-author-line"></span>
          </span>
          <span class="trending-stats">
            <span class="rank-badge skeleton-box"></span>
            <span class="skeleton-line skeleton-like-count"></span>
            <span class="btn like-button skeleton-button"></span>
          </span>
        </div>
      </article>
      <article class="card playlist-card skeleton-card">
        <div class="playlist-header">
          <span class="skeleton-line skeleton-title"></span>
          <span class="playlist-count skeleton-count"></span>
        </div>
        <div class="skeleton-line skeleton-text"></div>
        <div class="skeleton-line skeleton-text short"></div>
        <div class="playlist-footer">
          <span class="playlist-curator">
            <span class="skeleton-avatar"></span>
            <span class="skeleton-line skeleton-author-line"></span>
          </span>
          <span class="trending-stats">
            <span class="rank-badge skeleton-box"></span>
            <span class="skeleton-line skeleton-like-count"></span>
            <span class="btn like-button skeleton-button"></span>
          </span>
        </div>
      </article>
    </section>

    <div id="trending-pagination"></div>
  </section>
</BaseLayout>

<script is:inline src="/scripts/trending-page.js"></script>

<style is:global>
  .trending-summary {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
    flex-wrap: wrap;
    color: var(--color-text-muted);
  }

  .trending-grid {
    align-items: stretch;
  }

  /* Card structure — playlists page 패턴 일치 */
  .trending-page .playlist-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    color: var(--color-text);
  }

  .trending-page .playlist-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
  }

  .trending-page .playlist-title {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .trending-page .playlist-title a {
    color: var(--color-text);
    text-decoration: none;
  }

  .trending-page .playlist-title a:hover {
    color: var(--color-primary);
  }

  .trending-page .playlist-count {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    background: var(--color-bg-secondary);
    padding: 2px var(--space-sm);
    border-radius: var(--radius-sm);
    white-space: nowrap;
  }

  .trending-page .playlist-description {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .trending-page .playlist-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: auto;
  }

  .trending-page .playlist-curator {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .trending-page .curator-avatar {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    object-fit: cover;
  }

  /* Trending-specific: rank + likes + button */
  .trending-stats {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .rank-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-width: 2.5rem;
    padding: 0.2rem 0.5rem;
    border-radius: 999px;
    background: var(--color-accent);
    color: var(--color-text);
    font-weight: 800;
    font-size: 0.8rem;
  }

  .like-count {
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-weight: 600;
  }

  .like-button {
    font-size: 0.8rem;
    font-weight: 700;
    padding: var(--space-xs) var(--space-sm);
    /* Smooth color transition between unliked↔liked states. */
    transition: background-color 0.2s cubic-bezier(0.16, 1, 0.3, 1),
                border-color 0.2s cubic-bezier(0.16, 1, 0.3, 1),
                color 0.2s cubic-bezier(0.16, 1, 0.3, 1),
                transform 0.15s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .like-button:hover:not(:disabled) {
    transform: translateY(-1px);
  }
  .like-button:active:not(:disabled) {
    transform: translateY(0);
  }

  /*
   * Icon-width lock to prevent layout shift on toggle.
   * The hollow heart ♡ (U+2661) and solid heart ♥ (U+2665) have different intrinsic
   * widths in most fonts (♡ ≈ 12.8px vs ♥ ≈ 7.6px at base size). Forcing the icon
   * span to a fixed 1em box with centered content keeps the button's overall width
   * identical between liked and unliked states. The label "좋아요" therefore stays
   * pixel-perfectly anchored on click — no jitter.
   */
  .like-button-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1em;
    flex: 0 0 1em;
    line-height: 1;
    /* Slight scale animation on the icon itself signals the state change without moving the label. */
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .like-button.is-liked .like-button-icon {
    transform: scale(1.15);
  }

  .like-button.is-liked {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: white;
  }

  .like-button.is-liked:hover {
    color: white;
    background: var(--color-primary-hover);
    border-color: var(--color-primary-hover);
  }

  .like-button:disabled {
    opacity: 0.7;
    cursor: wait;
  }

  /* Skeleton loading */
  .skeleton-card {
    pointer-events: none;
  }

  .skeleton-box,
  .skeleton-line,
  .skeleton-avatar,
  .skeleton-count,
  .skeleton-like-count,
  .skeleton-button {
    background: linear-gradient(90deg, var(--color-bg-secondary) 25%, rgba(255, 255, 255, 0.5) 50%, var(--color-bg-secondary) 75%);
    background-size: 200% 100%;
    animation: trending-skeleton 1.4s ease-in-out infinite;
    color: transparent;
  }

  .skeleton-title {
    width: 72%;
    height: 1.4rem;
    border-radius: var(--radius-sm);
  }

  .skeleton-text {
    width: 100%;
    height: 1rem;
    border-radius: var(--radius-sm);
  }

  .skeleton-text.short {
    width: 80%;
  }

  .skeleton-avatar {
    width: 16px;
    height: 16px;
    border-radius: 50%;
  }

  .skeleton-author-line {
    width: 5rem;
    height: 0.8rem;
    border-radius: var(--radius-sm);
  }

  .skeleton-box {
    min-width: 2.5rem;
    min-height: 1.5rem;
    border-radius: 999px;
  }

  .skeleton-count {
    width: 2rem;
    height: 1.2rem;
    border-radius: var(--radius-sm);
  }

  .skeleton-like-count {
    width: 3rem;
    height: 0.8rem;
    border-radius: var(--radius-sm);
  }

  .skeleton-button {
    display: inline-flex;
    width: 4.5rem;
    height: 1.8rem;
    border-radius: var(--radius-sm);
    border: none;
  }

  @keyframes trending-skeleton {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  @media (max-width: 768px) {
    .trending-page .playlist-footer {
      flex-direction: column;
      align-items: flex-start;
      gap: var(--space-sm);
    }

    .trending-stats {
      width: 100%;
      justify-content: flex-end;
    }
  }
</style>
