---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="새 플레이리스트 만들기 — HoneyCombo" description="새로운 플레이리스트를 만들어보세요">
  <div class="page-header">
    <h1>📝 새 플레이리스트 만들기</h1>
    <p class="page-subtitle">나만의 기술 콘텐츠 모음을 만들어보세요</p>
  </div>

  <div class="submit-content">
    <div id="auth-check-loading" class="auth-message">
      <p>로그인 상태를 확인 중입니다...</p>
    </div>

    <div id="auth-required" class="auth-message" style="display: none;">
      <p>플레이리스트를 만들려면 로그인이 필요합니다.</p>
      <a href="/api/auth/github/login" class="btn btn-primary">GitHub로 로그인</a>
    </div>

    <form id="playlist-form" class="playlist-form" style="display: none;">
      <div class="form-group">
        <label for="title">제목 <span class="required">*</span></label>
        <input 
          type="text" 
          id="title" 
          name="title" 
          required 
          maxlength="200" 
          placeholder="예: 2024년 프론트엔드 트렌드 모음"
          class="form-control"
        />
        <div class="form-hint">최대 200자</div>
      </div>

      <div class="form-group">
        <label for="description">설명</label>
        <textarea 
          id="description" 
          name="description" 
          maxlength="500" 
          rows="4"
          placeholder="이 플레이리스트에 대한 설명을 적어주세요 (선택사항)"
          class="form-control"
        ></textarea>
        <div class="form-hint">최대 500자</div>
      </div>

      <div class="form-group" id="editor-type-group" style="display:none">
        <label>플레이리스트 타입</label>
        <label class="radio-label">
          <input type="checkbox" id="editor-toggle" />
          <div class="radio-content">
            <span class="radio-title">🏷️ 에디터 플레이리스트</span>
            <span class="radio-desc">에디터 큐레이션으로 등록됩니다. 승인 없이 즉시 공개됩니다.</span>
          </div>
        </label>
      </div>

      <div class="form-group" id="tags-group" style="display:none">
        <label for="tag-input">태그</label>
        <input 
          type="text" 
          id="tag-input" 
          placeholder="태그 입력 후 Enter (최대 5개)"
          class="form-control"
        />
        <div id="tags-container" class="tags-container"></div>
        <div class="form-hint">쉼표(,)나 Enter로 태그를 추가하세요</div>
      </div>

      <div class="form-group" id="visibility-group">
        <label>공개 범위</label>
        <div class="radio-group">
          <label class="radio-label">
            <input type="radio" name="visibility" value="unlisted" checked />
            <div class="radio-content">
              <span class="radio-title">비공개 링크</span>
              <span class="radio-desc">링크를 아는 사람만 볼 수 있습니다.</span>
            </div>
          </label>
          <label class="radio-label">
            <input type="radio" name="visibility" value="public" />
            <div class="radio-content">
              <span class="radio-title">공개 목록</span>
              <span class="radio-desc">사이트의 플레이리스트 목록에 노출됩니다. (에디터 승인 후 공개)</span>
            </div>
          </label>
        </div>
      </div>

      <div id="form-error" class="form-error" style="display: none;"></div>

      <div class="form-actions">
        <button type="submit" id="submit-btn" class="btn btn-primary btn-lg">
          <span class="btn-text">만들기</span>
          <span class="btn-spinner" style="display: none;">⏳</span>
        </button>
      </div>
    </form>
  </div>
</BaseLayout>

<script>
document.addEventListener('astro:page-load', async () => {
  const loadingEl = document.getElementById('auth-check-loading');
  const authRequiredEl = document.getElementById('auth-required');
  const formEl = document.getElementById('playlist-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = submitBtn?.querySelector('.btn-text') as HTMLElement;
  const btnSpinner = submitBtn?.querySelector('.btn-spinner') as HTMLElement;
  const errorEl = document.getElementById('form-error');

  let isAdmin = false;
  let tags: string[] = [];

  // Check auth
  try {
    const res = await fetch('/api/auth/me');
    if (res.ok) {
      const userData = await res.json();
      isAdmin = userData.is_admin === true;
      
      // Authed
      if (loadingEl) loadingEl.style.display = 'none';
      if (formEl) formEl.style.display = 'block';
      
      if (isAdmin) {
        const editorGroup = document.getElementById('editor-type-group');
        if (editorGroup) editorGroup.style.display = 'flex';
        
        const urlParams = new URLSearchParams(window.location.search);
        if (urlParams.get('type') === 'editor') {
          const editorToggle = document.getElementById('editor-toggle') as HTMLInputElement;
          if (editorToggle) {
            editorToggle.checked = true;
            handleEditorToggle(true);
          }
        }
      }
    } else {
      // Not authed
      if (loadingEl) loadingEl.style.display = 'none';
      if (authRequiredEl) authRequiredEl.style.display = 'block';
    }
  } catch (err) {
    if (loadingEl) loadingEl.style.display = 'none';
    if (authRequiredEl) authRequiredEl.style.display = 'block';
  }

  const editorToggle = document.getElementById('editor-toggle') as HTMLInputElement;
  if (editorToggle) {
    editorToggle.addEventListener('change', (e) => {
      handleEditorToggle((e.target as HTMLInputElement).checked);
    });
  }

  function handleEditorToggle(isChecked: boolean) {
    const visibilityGroup = document.getElementById('visibility-group');
    const tagsGroup = document.getElementById('tags-group');
    
    if (visibilityGroup) {
      visibilityGroup.style.display = isChecked ? 'none' : 'flex';
    }
    if (tagsGroup) {
      tagsGroup.style.display = isChecked ? 'flex' : 'none';
    }
  }

  const tagInput = document.getElementById('tag-input') as HTMLInputElement;
  const tagsContainer = document.getElementById('tags-container');

  if (tagInput && tagsContainer) {
    tagInput.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' || e.key === ',') {
        e.preventDefault();
        addTag(tagInput.value);
      }
    });
    
    tagInput.addEventListener('blur', () => {
      addTag(tagInput.value);
    });
  }

  function addTag(value: string) {
    const tag = value.trim().replace(/^#/, '').replace(/,/g, '');
    if (!tag) return;
    
    if (tags.length >= 5) {
      showError('태그는 최대 5개까지만 추가할 수 있습니다.');
      if (tagInput) tagInput.value = '';
      return;
    }
    
    if (!tags.includes(tag)) {
      tags.push(tag);
      renderTags();
    }
    
    if (tagInput) tagInput.value = '';
    if (errorEl) errorEl.style.display = 'none';
  }

  function removeTag(index: number) {
    tags.splice(index, 1);
    renderTags();
  }

  function renderTags() {
    if (!tagsContainer) return;
    tagsContainer.innerHTML = '';
    tags.forEach((tag, index) => {
      const tagEl = document.createElement('span');
      tagEl.className = 'tag-badge';
      tagEl.innerHTML = `
        ${tag}
        <button type="button" class="tag-remove" data-index="${index}">&times;</button>
      `;
      tagsContainer.appendChild(tagEl);
    });
    
    document.querySelectorAll('.tag-remove').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const index = parseInt((e.currentTarget as HTMLButtonElement).getAttribute('data-index') || '0', 10);
        removeTag(index);
      });
    });
  }

  // Handle form submit
  if (formEl) {
    formEl.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      if (errorEl) errorEl.style.display = 'none';
      
      const formData = new FormData(formEl);
      const title = formData.get('title')?.toString().trim();
      const description = formData.get('description')?.toString().trim();
      const visibility = formData.get('visibility')?.toString();

      if (!title) {
        showError('제목을 입력해주세요.');
        return;
      }

      if (title.length > 200) {
        showError('제목은 200자를 초과할 수 없습니다.');
        return;
      }

      if (description && description.length > 500) {
        showError('설명은 500자를 초과할 수 없습니다.');
        return;
      }

      // Set loading state
      submitBtn.disabled = true;
      if (btnText) btnText.style.display = 'none';
      if (btnSpinner) btnSpinner.style.display = 'inline-block';

      try {
        const res = await fetch('/api/playlists', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            title,
            description,
            visibility: editorToggle?.checked ? 'public' : visibility,
            playlist_type: editorToggle?.checked ? 'editor' : 'community',
            tags: editorToggle?.checked ? tags : []
          }),
        });

        if (!res.ok) {
          const data = await res.json().catch(() => ({}));
          throw new Error(data.error || '플레이리스트 생성에 실패했습니다.');
        }

        const data = await res.json();
        // Redirect to the new playlist page
        window.location.href = `/p/${data.id}`;
      } catch (err: unknown) {
        const errorMessage = err instanceof Error ? err.message : '알 수 없는 오류가 발생했습니다.';
        showError(errorMessage);
        
        // Reset loading state
        submitBtn.disabled = false;
        if (btnText) btnText.style.display = 'inline-block';
        if (btnSpinner) btnSpinner.style.display = 'none';
      }
    });
  }

  function showError(msg: string) {
    if (errorEl) {
      errorEl.textContent = msg;
      errorEl.style.display = 'block';
    }
  }
});
</script>

<style>
.page-header { margin-bottom: var(--space-xl); }
.page-header h1 { font-size: 2rem; font-weight: 800; }
.page-subtitle { color: var(--color-text-muted); margin-top: var(--space-xs); }
.submit-content { max-width: 600px; }

.auth-message {
  padding: var(--space-xl);
  text-align: center;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border);
}
.auth-message p {
  margin-bottom: var(--space-md);
  color: var(--color-text-muted);
}

.playlist-form {
  display: flex;
  flex-direction: column;
  gap: var(--space-lg);
}

.form-group {
  display: flex;
  flex-direction: column;
  gap: var(--space-xs);
}

.form-group label {
  font-weight: 600;
  color: var(--color-text);
}

.required {
  color: var(--color-danger);
}

.form-control {
  padding: var(--space-sm) var(--space-md);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-family: inherit;
  font-size: 1rem;
  background: var(--color-bg);
  color: var(--color-text);
  transition: border-color 0.2s, box-shadow 0.2s;
}

.form-control:focus {
  outline: none;
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
}

.form-hint {
  font-size: 0.8rem;
  color: var(--color-text-muted);
  text-align: right;
}

.radio-group {
  display: flex;
  flex-direction: column;
  gap: var(--space-sm);
}

.radio-label {
  display: flex;
  align-items: flex-start;
  gap: var(--space-sm);
  padding: var(--space-md);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition: border-color 0.2s, background 0.2s;
}

.radio-label:hover {
  background: var(--color-bg-secondary);
}

.radio-label:has(input:checked) {
  border-color: var(--color-primary);
  background: rgba(37, 99, 235, 0.05);
}

.radio-label input[type="radio"] {
  margin-top: 4px;
  accent-color: var(--color-primary);
}

.radio-content {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.radio-title {
  font-weight: 600;
  color: var(--color-text);
}

.radio-desc {
  font-size: 0.85rem;
  color: var(--color-text-muted);
}

.form-error {
  padding: var(--space-sm) var(--space-md);
  background: rgba(239, 68, 68, 0.1);
  color: var(--color-danger);
  border-radius: var(--radius-sm);
  font-size: 0.9rem;
}

.form-actions {
  margin-top: var(--space-md);
}

.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-sm) var(--space-lg);
  border-radius: var(--radius-md);
  font-weight: 600;
  font-size: 0.95rem;
  transition: all 0.15s;
  text-decoration: none;
  border: none;
  cursor: pointer;
}

.btn-lg {
  width: 100%;
  padding: var(--space-md);
  font-size: 1.05rem;
}

.btn-primary { background: var(--color-primary); color: white; }
.btn-primary:hover { background: var(--color-primary-hover); color: white; text-decoration: none; }
.btn-primary:disabled { opacity: 0.7; cursor: not-allowed; }

.tags-container {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
  margin-top: var(--space-xs);
}

/* Tag badges — dynamic content (appendChild), needs :global() */
.submit-content :global(.tag-badge) {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 4px 8px;
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-size: 0.85rem;
  color: var(--color-text);
}

.submit-content :global(.tag-remove) {
  background: none;
  border: none;
  color: var(--color-text-muted);
  cursor: pointer;
  font-size: 1.1rem;
  line-height: 1;
  padding: 0 2px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.submit-content :global(.tag-remove:hover) {
  color: var(--color-danger);
}
</style>
