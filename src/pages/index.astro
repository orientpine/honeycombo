---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import { compareArticles } from '../lib/article-sort';
import PersonalizationBar from '../components/PersonalizationBar.astro';

const MAX_RECENT = 6;

const curatedEntries = await getCollection('curated', (entry: any) => entry.data.status === 'approved').catch((err: unknown) => {
  console.error('Failed to load collection:', err);
  return [];
});
const feedEntries = await getCollection('feeds').catch((err: unknown) => {
  console.error('Failed to load collection:', err);
  return [];
});

const allArticles = [
  ...curatedEntries.map((e: any) => ({ ...e.data, _type: 'curated' as const, _id: e.id })),
  ...feedEntries.map((e: any) => ({ ...e.data, _type: 'feed' as const, _id: e.id })),
].sort(compareArticles);

const allTags = [...new Set(allArticles.flatMap(a => a.tags))].sort();
const recentArticles = allArticles.slice(0, MAX_RECENT);
---

<BaseLayout title="HoneyCombo — 기술 뉴스 큐레이션">
  <section class="hero">
    <div class="hero-image-wrapper">
      <img src="/main_image.jpg" alt="HoneyCombo - 기술 뉴스 큐레이션" class="hero-logo" loading="eager" />
    </div>
    <p class="hero-subtitle">개발자를 위한 기술 뉴스 큐레이션</p>
    <div class="hero-actions">
      <a href="/articles" class="btn btn-primary">기사 보기</a>
      <a href="/trending" class="btn btn-secondary">트렌드 랭킹</a>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">최근 기사</h2>
    {allTags.length > 0 && <PersonalizationBar availableTags={allTags} />}
    {recentArticles.length === 0 ? (
      <p class="empty-state" data-testid="article-list-empty">
        기사를 수집 중입니다. 잠시 후 다시 확인해주세요.
      </p>
    ) : (
      <div class="article-grid grid grid-3" data-testid="article-list">
        {recentArticles.map(article => (
          <ArticleCard
            id={article._id}
            title={article.title}
            url={article.url}
            source={article.source}
            type={article.type}
            description={article.description}
            tags={article.tags}
            date={'submitted_at' in article ? article.submitted_at : article.published_at}
            thumbnail_url={article.thumbnail_url}
            isExternal={article._type === 'feed'}
            slug={article._type === 'curated' ? article._id : undefined}
          />
        ))}
      </div>
    )}
  </section>
</BaseLayout>

<style>
.hero {
  text-align: center;
  padding: var(--space-2xl) 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  overflow: hidden;
  z-index: 1;
}
.hero::before {
  content: '';
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 150%;
  max-width: 1200px;
  height: 150%;
  background: radial-gradient(circle, rgba(252, 185, 36, 0.15) 0%, rgba(245, 124, 34, 0.05) 35%, transparent 70%);
  z-index: -2;
  pointer-events: none;
}
.hero::after {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-image: url("data:image/svg+xml,%3Csvg width='42' height='74' viewBox='0 0 28 49' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23F57C22' fill-opacity='0.25'%3E%3Cpath d='M13.99 9.25l13 7.5v15l-13 7.5L1 31.75v-15l12.99-7.5zM3 17.9v12.7l10.99 6.34 11-6.35V17.9l-11-6.34L3 17.9zM0 15l12.98-7.5V0h-2v6.35L0 12.69v2.3zm0 18.5L12.98 41v8h-2v-6.85L0 35.81v-2.3zM15 0v7.5L27.99 15H28v-2.31h-.01L17 6.35V0h-2zm0 49v-8l12.99-7.5H28v2.31h-.01L17 42.15V49h-2z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  background-size: 42px 74px;
  background-position: center;
  z-index: -1;
  pointer-events: none;
  mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
  -webkit-mask-image: radial-gradient(ellipse at center, black 20%, transparent 70%);
}
.hero-image-wrapper {
  position: relative;
  width: 100%;
  max-width: 600px;
  margin-bottom: var(--space-md);
  z-index: 1;
  display: flex;
  justify-content: center;
}
.hero-logo {
  width: 100%;
  max-height: 280px;
  object-fit: contain;
  border-radius: 24px;
  background-color: #ffffff;
  box-shadow: 
    0 0 30px 15px #ffffff,
    0 0 60px 30px rgba(252, 185, 36, 0.15),
    0 10px 30px rgba(245, 124, 34, 0.08);
  position: relative;
  z-index: 2;
}
.hero-subtitle { font-size: 1.25rem; color: var(--color-text-muted); margin-bottom: var(--space-xl); }
.hero-actions { display: flex; gap: var(--space-md); justify-content: center; flex-wrap: wrap; }
.btn {
  display: inline-flex;
  align-items: center;
  padding: var(--space-sm) var(--space-lg);
  border-radius: var(--radius-md);
  font-weight: 600;
  font-size: 0.95rem;
  transition: all 0.15s;
  text-decoration: none;
}
.btn-primary { background: var(--color-primary); color: white; }
.btn-primary:hover { background: var(--color-primary-hover); color: white; text-decoration: none; }
.btn-secondary { background: var(--color-bg-secondary); color: var(--color-text); border: 1px solid var(--color-border); }
.btn-secondary:hover { border-color: var(--color-primary); color: var(--color-primary); text-decoration: none; }
.section { margin-top: var(--space-2xl); }
.section-title { font-size: 1.5rem; font-weight: 700; margin-bottom: var(--space-lg); }
.empty-state { color: var(--color-text-muted); text-align: center; padding: var(--space-2xl); }
</style>
