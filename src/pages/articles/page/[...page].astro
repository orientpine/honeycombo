---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import Pagination from '../../../components/Pagination.astro';
import TagFilter from '../../../components/TagFilter.astro';
import { compareArticles } from '../../../lib/article-sort';
import PersonalizationBar from '../../../components/PersonalizationBar.astro';
import SourceFilter from '../../../components/SourceFilter.astro';
import { serializeArticles } from '../../../lib/serialize-articles';


export async function getStaticPaths() {
  const ITEMS_PER_PAGE = 20;
  const curatedEntries = await getCollection('curated', (entry: any) => entry.data.status === 'approved').catch((err: unknown) => {
    console.error('Failed to load collection:', err);
    return [];
  });
  const feedEntries = await getCollection('feeds').catch((err: unknown) => {
    console.error('Failed to load collection:', err);
    return [];
  });
  
  const allArticles = [
    ...curatedEntries.map((e: any) => ({
      ...e.data,
      _type: (e.data.source === 'User Submission' || e.data.source === 'YouTube') && e.data.submitted_by ? 'submitted' as const : 'curated' as const,
      _id: e.id,
    })),
    ...feedEntries.map((e: any) => ({ ...e.data, _type: 'feed' as const, _id: e.id })),
  ].sort(compareArticles);
  
  const totalPages = Math.max(1, Math.ceil(allArticles.length / ITEMS_PER_PAGE));
  
  // Generate pages 2..N (page 1 is handled by index.astro)
  return Array.from({ length: Math.max(0, totalPages - 1) }, (_, i) => ({
    params: { page: String(i + 2) },
    props: {
      articles: allArticles.slice((i + 1) * ITEMS_PER_PAGE, (i + 2) * ITEMS_PER_PAGE),
      currentPage: i + 2,
      totalPages,
      allTags: [...new Set(allArticles.flatMap(a => a.tags))].sort(),
      allArticlesJson: serializeArticles(allArticles),
      curatedCount: allArticles.filter(a => a._type === 'curated').length,
      submittedCount: allArticles.filter(a => a._type === 'submitted').length,
      feedCount: allArticles.filter(a => a._type === 'feed').length,
    },
  }));
}

const { articles, currentPage, totalPages, allTags, allArticlesJson, curatedCount, submittedCount, feedCount } = Astro.props;
---

<BaseLayout title={`기사 ${currentPage}페이지 — HoneyCombo`}>
  <header class="page-header">
    <h1 class="page-title">기사</h1>
    <p class="page-description">최신 기술 뉴스와 에디터 큐레이션</p>
  </header>
  
  <SourceFilter curatedCount={curatedCount} submittedCount={submittedCount} feedCount={feedCount} />

  {allTags.length > 0 && <PersonalizationBar availableTags={allTags} />}
  {allTags.length > 0 && <TagFilter tags={allTags} />}
  
  <div class="article-grid grid grid-3" data-testid="article-list">
    {articles.map(article => (
      <ArticleCard
        id={article._id}
        title={article.title}
        url={article.url}
        source={article.source}
        type={article.type}
        description={article.description}
        tags={article.tags}
        date={'submitted_at' in article ? article.submitted_at : article.published_at}
        thumbnail_url={article.thumbnail_url}
        isExternal={false}
        slug={article._id}
        articleOrigin={article._type}
      />
    ))}
  </div>
  
  <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/articles" />
  <script type="application/json" id="all-articles-data" set:html={allArticlesJson} />
</BaseLayout>

<style>
.article-grid { margin-top: var(--space-md); }
</style>
