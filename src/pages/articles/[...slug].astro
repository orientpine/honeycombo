---
import { getCollection } from 'astro:content';
// biome-ignore lint/correctness/noUnusedImports: used in template
import ArticleMeta from '../../components/ArticleMeta.astro';
// biome-ignore lint/correctness/noUnusedImports: used in template
import Comments from '../../components/Comments.astro';
// biome-ignore lint/correctness/noUnusedImports: used in template
import RelatedArticles from '../../components/RelatedArticles.astro';
// biome-ignore lint/correctness/noUnusedImports: used in template
import BaseLayout from '../../layouts/BaseLayout.astro';
// biome-ignore lint/correctness/noUnusedImports: used in template
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
// biome-ignore lint/correctness/noUnusedImports: used in template
import ContentTabs from '../../components/ContentTabs.astro';

export async function getStaticPaths() {
  const articles = await getCollection('curated', (entry: any) => entry.data.status === 'approved').catch((err: unknown) => {
    console.error('Failed to load collection:', err);
    return [];
  });
  return articles.map((entry: any) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props as { entry: any };
const article = entry.data;
---

<BaseLayout
  title={`${article.title} — HoneyCombo`}
  description={article.description || `${article.title} - ${article.source}에서 큐레이션된 기사`}
  ogImage={article.thumbnail_url}
  ogType="article"
>
  <article class="article-detail" data-testid="article-detail">
    <header class="article-header">
      <h1 class="article-detail-title">{article.title}</h1>
      <ArticleMeta
        source={article.source}
        date={article.submitted_at}
        tags={article.tags}
        url={article.url}
      />
    </header>

    {article.type === 'youtube' ? (
      <YouTubeEmbed url={article.url} title={article.title} thumbnail={article.thumbnail_url} />
    ) : article.thumbnail_url && (
      <div class="article-hero-image">
        <img src={article.thumbnail_url} alt={article.title} loading="eager" />
      </div>
    )}

    <ContentTabs description={article.description} url={article.url} />

    <Comments />

    <RelatedArticles currentId={entry.id} tags={article.tags} />
  </article>
</BaseLayout>

<style>
.article-detail { max-width: 800px; margin: 0 auto; }
.article-header { margin-bottom: var(--space-xl); }
.article-detail-title { font-size: 2rem; font-weight: 800; line-height: 1.3; margin-bottom: var(--space-md); }
.article-hero-image { margin-bottom: var(--space-xl); border-radius: var(--radius-md); overflow: hidden; }
.article-hero-image img { width: 100%; max-height: 400px; object-fit: cover; }
.article-detail-content { margin-bottom: var(--space-xl); }
</style>
