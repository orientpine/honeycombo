---
import { getCollection } from 'astro:content';
// biome-ignore lint/correctness/noUnusedImports: used in template
import ArticleMeta from '../../components/ArticleMeta.astro';
// biome-ignore lint/correctness/noUnusedImports: used in template
import Comments from '../../components/Comments.astro';
// biome-ignore lint/correctness/noUnusedImports: used in template
import RelatedArticles from '../../components/RelatedArticles.astro';
// biome-ignore lint/correctness/noUnusedImports: used in template
import BaseLayout from '../../layouts/BaseLayout.astro';
// biome-ignore lint/correctness/noUnusedImports: used in template
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';

export async function getStaticPaths() {
  const articles = await getCollection('curated', entry => entry.data.status === 'approved').catch(() => []);
  return articles.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const article = entry.data;
---

<BaseLayout
  title={`${article.title} — HoneyCombo`}
  description={article.description || `${article.title} - ${article.source}에서 큐레이션된 기사`}
  ogImage={article.thumbnail_url}
  ogType="article"
>
  <article class="article-detail" data-testid="article-detail">
    <header class="article-header">
      <h1 class="article-detail-title">{article.title}</h1>
      <ArticleMeta
        source={article.source}
        date={article.submitted_at}
        tags={article.tags}
        url={article.url}
      />
    </header>

    {article.type === 'youtube' ? (
      <YouTubeEmbed url={article.url} title={article.title} thumbnail={article.thumbnail_url} />
    ) : article.thumbnail_url && (
      <div class="article-hero-image">
        <img src={article.thumbnail_url} alt={article.title} loading="eager" />
      </div>
    )}

    {article.description && (
      <div class="article-summary">
        <p>{article.description}</p>
      </div>
    )}

    <div class="article-cta">
      <a href={article.url} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
        원문 읽기 →
      </a>
    </div>

    <Comments />

    <RelatedArticles currentId={entry.id} tags={article.tags} />
  </article>
</BaseLayout>

<style>
.article-detail { max-width: 800px; margin: 0 auto; }
.article-header { margin-bottom: var(--space-xl); }
.article-detail-title { font-size: 2rem; font-weight: 800; line-height: 1.3; margin-bottom: var(--space-md); }
.article-hero-image { margin-bottom: var(--space-xl); border-radius: var(--radius-md); overflow: hidden; }
.article-hero-image img { width: 100%; max-height: 400px; object-fit: cover; }
.article-summary { background: var(--color-bg-secondary); border-left: 4px solid var(--color-primary); padding: var(--space-md) var(--space-lg); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; margin-bottom: var(--space-xl); }
.article-summary p { color: var(--color-text); line-height: 1.7; }
.article-cta { margin: var(--space-xl) 0; }
.btn { display: inline-flex; align-items: center; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-md); font-weight: 600; font-size: 0.95rem; transition: all 0.15s; text-decoration: none; }
.btn-primary { background: var(--color-primary); color: white; }
.btn-primary:hover { background: var(--color-primary-hover); color: white; text-decoration: none; }
</style>
