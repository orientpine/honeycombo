---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleMeta from '../../components/ArticleMeta.astro';
import RelatedArticles from '../../components/RelatedArticles.astro';

export async function getStaticPaths() {
  const articles = await getCollection('curated', entry => entry.data.status === 'approved');
  return articles.map(entry => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, url, source, type, description, tags, submitted_at, thumbnail_url } = entry.data;
---

<BaseLayout
  title={`${title} — HoneyCombo`}
  description={description || `${title} - ${source}에서 큐레이션된 기사`}
  ogImage={thumbnail_url}
  ogType="article"
>
  <article class="article-detail" data-testid="article-detail">
    <header class="article-header">
      <h1 class="article-detail-title">{title}</h1>
      <ArticleMeta
        source={source}
        date={submitted_at}
        tags={tags}
        url={url}
      />
    </header>

    {thumbnail_url && (
      <div class="article-hero-image">
        <img src={thumbnail_url} alt={title} loading="eager" />
      </div>
    )}

    {description && (
      <div class="article-summary">
        <p>{description}</p>
      </div>
    )}

    <div class="article-cta">
      <a href={url} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
        원문 읽기 →
      </a>
    </div>

    <!-- Giscus comments slot (activated in T17) -->
    <div id="comments-slot" data-testid="comments-slot"></div>

    <RelatedArticles currentId={entry.id} tags={tags} />
  </article>
</BaseLayout>

<style>
.article-detail { max-width: 800px; margin: 0 auto; }
.article-header { margin-bottom: var(--space-xl); }
.article-detail-title { font-size: 2rem; font-weight: 800; line-height: 1.3; margin-bottom: var(--space-md); }
.article-hero-image { margin-bottom: var(--space-xl); border-radius: var(--radius-md); overflow: hidden; }
.article-hero-image img { width: 100%; max-height: 400px; object-fit: cover; }
.article-summary { background: var(--color-bg-secondary); border-left: 4px solid var(--color-primary); padding: var(--space-md) var(--space-lg); border-radius: 0 var(--radius-sm) var(--radius-sm) 0; margin-bottom: var(--space-xl); }
.article-summary p { color: var(--color-text); line-height: 1.7; }
.article-cta { margin: var(--space-xl) 0; }
.btn { display: inline-flex; align-items: center; padding: var(--space-sm) var(--space-lg); border-radius: var(--radius-md); font-weight: 600; font-size: 0.95rem; transition: all 0.15s; text-decoration: none; }
.btn-primary { background: var(--color-primary); color: white; }
.btn-primary:hover { background: var(--color-primary-hover); color: white; text-decoration: none; }
</style>