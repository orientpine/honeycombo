---
import { getCollection } from 'astro:content';
// biome-ignore lint/correctness/noUnusedImports: used in template
import ArticleMeta from '../../components/ArticleMeta.astro';
// biome-ignore lint/correctness/noUnusedImports: used in template
import Comments from '../../components/Comments.astro';
// biome-ignore lint/correctness/noUnusedImports: used in template
import RelatedArticles from '../../components/RelatedArticles.astro';
// biome-ignore lint/correctness/noUnusedImports: used in template
import BaseLayout from '../../layouts/BaseLayout.astro';
// biome-ignore lint/correctness/noUnusedImports: used in template
import YouTubeEmbed from '../../components/YouTubeEmbed.astro';
// biome-ignore lint/correctness/noUnusedImports: used in template
import ContentTabs from '../../components/ContentTabs.astro';
import AddToPlaylist from '../../components/AddToPlaylist.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import BookmarkButton from '../../components/BookmarkButton.astro';
import { stripMarkdownForPreview } from '../../lib/render-summary';

export async function getStaticPaths() {
  const curatedEntries = await getCollection('curated', (entry: any) => entry.data.status === 'approved').catch((err: unknown) => {
    console.error('Failed to load collection:', err);
    return [];
  });
  const feedEntries = await getCollection('feeds').catch((err: unknown) => {
    console.error('Failed to load collection:', err);
    return [];
  });
  return [
    ...curatedEntries.flatMap((entry: any) => {
      const paths = [{ params: { slug: entry.id }, props: { entry, collection: 'curated' as const } }];
      // Backward compatibility: also generate filename-only path for source_ids stored without year/month prefix
      const parts = entry.id.split('/');
      if (parts.length > 1) {
        const filename = parts[parts.length - 1];
        paths.push({ params: { slug: filename }, props: { entry, collection: 'curated' as const } });
      }
      return paths;
    }),
    ...feedEntries.flatMap((entry: any) => {
      const paths = [{ params: { slug: entry.id }, props: { entry, collection: 'feeds' as const } }];
      const parts = entry.id.split('/');
      if (parts.length > 1) {
        const filename = parts[parts.length - 1];
        paths.push({ params: { slug: filename }, props: { entry, collection: 'feeds' as const } });
      }
      return paths;
    }),
  ];
}

const { entry, collection } = Astro.props as { entry: any; collection: 'curated' | 'feeds' };
const article = entry.data;
const articleDate = 'submitted_at' in article ? article.submitted_at : article.published_at;
const sourceType = collection === 'feeds' ? 'feed' : 'curated';
// Always use entry.id for canonical path (handles alias pages with filename-only slugs)
const canonicalPath = `/articles/${entry.id}/`;
const pageUrl = new URL(canonicalPath, 'https://honeycombo.pages.dev').href;
---

<BaseLayout
  title={`${article.title} — HoneyCombo`}
  description={article.description ? stripMarkdownForPreview(article.description) : `${article.title} - ${article.source}에서 큐레이션된 기사`}
  ogImage={article.thumbnail_url}
  ogType="article"
  canonicalPath={canonicalPath}
>
  <article class="article-detail" data-testid="article-detail">
    <header class="article-header">
      <h1 class="article-detail-title">{article.title}</h1>
      <ArticleMeta
        source={article.source}
        date={articleDate}
        tags={article.tags}
      />
    </header>

    <div class="article-actions">
      <div class="actions-left">
        <BookmarkButton
          articleId={entry.id}
          title={article.title}
          url={article.url}
          description={article.description}
          sourceType={sourceType}
        />
        <ShareButtons title={article.title} url={pageUrl} />
      </div>
      <AddToPlaylist 
        articleId={entry.id}
        title={article.title}
        url={article.url}
        description={article.description}
        sourceType={sourceType}
      />
    </div>

    {article.type === 'youtube' ? (
      <YouTubeEmbed url={article.url} title={article.title} thumbnail={article.thumbnail_url} />
    ) : article.thumbnail_url && (
      <div class="article-hero-image">
        <img src={article.thumbnail_url} alt={article.title} loading="eager" />
      </div>
    )}

    <ContentTabs description={article.description} url={article.url} />

    <section id="comments">
      <Comments term={canonicalPath} />
    </section>

    <RelatedArticles currentId={entry.id} tags={article.tags} />
  </article>
</BaseLayout>

<style>
.article-detail { max-width: 800px; margin: 0 auto; }
.article-header { margin-bottom: var(--space-lg); }
.article-detail-title { font-size: 2rem; font-weight: 800; line-height: 1.3; margin-bottom: var(--space-md); }
.article-actions {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-sm);
  margin-bottom: var(--space-lg);
  padding: var(--space-sm) 0;
  border-top: 1px solid var(--color-border);
  border-bottom: 1px solid var(--color-border);
}
.actions-left {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
}
.article-hero-image { margin-bottom: var(--space-xl); border-radius: var(--radius-md); overflow: hidden; }
.article-hero-image img { width: 100%; max-height: 400px; object-fit: cover; }
@media (max-width: 768px) {
  .article-actions { flex-wrap: wrap; }
}
</style>
