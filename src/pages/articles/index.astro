---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import Pagination from '../../components/Pagination.astro';
import TagFilter from '../../components/TagFilter.astro';
import PersonalizationBar from '../../components/PersonalizationBar.astro';
import SourceFilter from '../../components/SourceFilter.astro';
import { compareArticles } from '../../lib/article-sort';
import { serializeArticles } from '../../lib/serialize-articles';

const ITEMS_PER_PAGE = 20;

// Get approved curated articles (에디터 추천)
const approvedEntries = await getCollection('curated', (entry: any) => entry.data.status === 'approved').catch((err: unknown) => {
  console.error('Failed to load collection:', err);
  return [];
});

// Get pending curated articles (제출 기사 - 검토 대기)
const pendingEntries = await getCollection('curated', (entry: any) => entry.data.status === 'pending').catch((err: unknown) => {
  console.error('Failed to load collection:', err);
  return [];
});

// Get all feed articles
const feedEntries = await getCollection('feeds').catch((err: unknown) => {
  console.error('Failed to load collection:', err);
  return [];
});

// Merge and sort (shared comparator)
const allArticles = [
  ...approvedEntries.map((e: any) => ({ ...e.data, _type: 'curated' as const, _id: e.id })),
  ...pendingEntries.map((e: any) => ({ ...e.data, _type: 'submitted' as const, _id: e.id })),
  ...feedEntries.map((e: any) => ({ ...e.data, _type: 'feed' as const, _id: e.id })),
].sort(compareArticles);

const totalPages = Math.max(1, Math.ceil(allArticles.length / ITEMS_PER_PAGE));
const pageArticles = allArticles.slice(0, ITEMS_PER_PAGE);

// Collect all unique tags
const allTags = [...new Set(allArticles.flatMap(a => a.tags))].sort();
const curatedCount = allArticles.filter(a => a._type === 'curated').length;
const submittedCount = allArticles.filter(a => a._type === 'submitted').length;
const feedCount = allArticles.filter(a => a._type === 'feed').length;
const allArticlesJson = serializeArticles(allArticles);
---

<BaseLayout title="기사 목록 — HoneyCombo" description="최신 기술 뉴스와 큐레이션 기사">
  <div class="page-header">
    <h1>기사</h1>
    <p class="page-subtitle">최신 기술 뉴스와 에디터 큐레이션</p>
  </div>
  
  <SourceFilter curatedCount={curatedCount} submittedCount={submittedCount} feedCount={feedCount} />

  {allTags.length > 0 && <PersonalizationBar availableTags={allTags} />}

  {allTags.length > 0 && <TagFilter tags={allTags} />}
  
  {allArticles.length === 0 ? (
    <p class="empty-state" data-testid="article-list-empty">
      기사를 수집 중입니다. 잠시 후 다시 확인해주세요.
    </p>
  ) : (
    <div class="article-grid grid grid-3" data-testid="article-list">
      {pageArticles.map(article => (
        <ArticleCard
          id={article._id}
          title={article.title}
          url={article.url}
          source={article.source}
          type={article.type}
          description={article.description}
          tags={article.tags}
          date={'submitted_at' in article ? article.submitted_at : article.published_at}
          thumbnail_url={article.thumbnail_url}
          isExternal={article._type === 'feed' || article._type === 'submitted'}
          slug={article._type === 'curated' ? article._id : undefined}
          articleOrigin={article._type}
        />
      ))}
    </div>
  )}
  
  <Pagination currentPage={1} totalPages={totalPages} baseUrl="/articles" />
  <script type="application/json" id="all-articles-data" set:html={allArticlesJson} />
</BaseLayout>

<style>
.page-header { margin-bottom: var(--space-xl); }
.page-header h1 { font-size: 2rem; font-weight: 800; }
.page-subtitle { color: var(--color-text-muted); margin-top: var(--space-xs); }
.article-grid { margin-top: var(--space-md); }
.empty-state { text-align: center; padding: var(--space-2xl); color: var(--color-text-muted); }
</style>
