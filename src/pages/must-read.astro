---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import MustReadCard from '../components/MustReadCard.astro';

// Get today's or latest must-read
const allMustRead = await getCollection('mustRead').catch(() => []);
const latest = allMustRead.sort((a, b) => b.data.date.localeCompare(a.data.date))[0];
---

<BaseLayout title="Must-read — HoneyCombo" description="오늘 꼭 읽어야 할 기술 기사">
  <div class="page-header">
    <h1>⭐ Must-read</h1>
    <p class="page-subtitle">
      {latest ? `${latest.data.date} 기준` : '매일 업데이트'}
    </p>
  </div>

  {!latest || !latest.data.items.length ? (
    <div class="empty-state" data-testid="must-read-list">
      <p>⭐ Must-read 목록을 준비 중입니다.</p>
    </div>
  ) : (
    <div class="must-read-grid" data-testid="must-read-list">
      {latest.data.items.map((articleId, i) => (
        <MustReadCard articleId={articleId} rank={i + 1} />
      ))}
    </div>
  )}
</BaseLayout>

<style>
.page-header { margin-bottom: var(--space-xl); }
.page-header h1 { font-size: 2rem; font-weight: 800; }
.page-subtitle { color: var(--color-text-muted); margin-top: var(--space-xs); }
.must-read-grid { display: flex; flex-direction: column; gap: var(--space-md); }
.empty-state { text-align: center; padding: var(--space-2xl); color: var(--color-text-muted); background: var(--color-bg-secondary); border-radius: var(--radius-lg); border: 1px dashed var(--color-border); }
</style>
