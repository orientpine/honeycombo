---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="플레이리스트 관리 — HoneyCombo" description="관리자 플레이리스트 승인/반려">
  <header class="page-header">
    <h1 class="page-title">🛡️ 플레이리스트 승인 관리</h1>
    <p class="page-description">커뮤니티 공개 요청된 플레이리스트를 검토합니다</p>
  </header>

  <div class="admin-content">
    <div id="loading" class="state-message">
      <p>불러오는 중...</p>
    </div>

    <div id="auth-required" class="state-message" style="display: none;">
      <p>관리자 로그인이 필요합니다.</p>
      <a href="/api/auth/github/login" class="btn btn-primary">GitHub로 로그인</a>
    </div>

    <div id="forbidden" class="state-message" style="display: none;">
      <p>관리자 권한이 없습니다.</p>
      <a href="/" class="btn">홈으로 돌아가기</a>
    </div>

    <div id="error-state" class="state-message error-message" style="display: none;">
      <p id="error-text">목록을 불러오는데 실패했습니다.</p>
      <button id="retry-btn" class="btn">다시 시도</button>
    </div>

    <div id="empty-state" class="state-message" style="display: none;">
      <p>승인 대기 중인 플레이리스트가 없습니다. 🎉</p>
    </div>

    <div id="playlists-grid" class="grid grid-1" style="display: none;">
    </div>
  </div>
</BaseLayout>

<script>
document.addEventListener('astro:page-load', () => {
  const loadingEl = document.getElementById('loading');
  const authRequiredEl = document.getElementById('auth-required');
  const forbiddenEl = document.getElementById('forbidden');
  const errorStateEl = document.getElementById('error-state');
  const errorTextEl = document.getElementById('error-text');
  const emptyStateEl = document.getElementById('empty-state');
  const gridEl = document.getElementById('playlists-grid');
  const retryBtn = document.getElementById('retry-btn');

  function hideAll() {
    [loadingEl, authRequiredEl, forbiddenEl, errorStateEl, emptyStateEl, gridEl].forEach(el => {
      if (el) el.style.display = 'none';
    });
  }

  function escapeHtml(unsafe: string) {
    return unsafe
      .replace(/&/g, "&amp;")
      .replace(/</g, "&lt;")
      .replace(/>/g, "&gt;")
      .replace(/"/g, "&quot;")
      .replace(/'/g, "&#039;");
  }

  async function loadPending() {
    hideAll();
    if (loadingEl) loadingEl.style.display = 'block';

    try {
      const authRes = await fetch('/api/auth/me');
      if (!authRes.ok) {
        hideAll();
        if (authRequiredEl) authRequiredEl.style.display = 'block';
        return;
      }

      const res = await fetch('/api/admin/playlists/pending');

      if (res.status === 403) {
        hideAll();
        if (forbiddenEl) forbiddenEl.style.display = 'block';
        return;
      }

      if (!res.ok) {
        throw new Error('목록을 불러오는데 실패했습니다.');
      }

      const data = await res.json();
      const playlists = data.playlists || [];

      hideAll();

      if (playlists.length === 0) {
        if (emptyStateEl) emptyStateEl.style.display = 'block';
        return;
      }

      renderPlaylists(playlists);
      if (gridEl) gridEl.style.display = 'grid';
    } catch (err: unknown) {
      hideAll();
      if (errorStateEl) errorStateEl.style.display = 'block';
      if (errorTextEl) {
        errorTextEl.textContent = err instanceof Error ? err.message : '알 수 없는 오류';
      }
    }
  }

  function renderPlaylists(playlists: any[]) {
    if (!gridEl) return;
    gridEl.innerHTML = '';

    playlists.forEach(playlist => {
      const card = document.createElement('div');
      card.className = 'card pending-card';
      card.setAttribute('data-id', playlist.id);

      const date = new Date(playlist.updated_at || playlist.created_at).toLocaleDateString('ko-KR', {
        year: 'numeric', month: 'short', day: 'numeric'
      });

      card.innerHTML = `
        <div class="pending-header">
          <div class="pending-info">
            <h3 class="pending-title">
              <a href="/p/${escapeHtml(playlist.id)}" target="_blank">${escapeHtml(playlist.title)}</a>
            </h3>
            ${playlist.description ? `<p class="pending-description">${escapeHtml(playlist.description)}</p>` : ''}
          </div>
        </div>
        <div class="pending-meta">
          <span class="pending-author">
            ${playlist.avatar_url ? `<img src="${escapeHtml(playlist.avatar_url)}" alt="" class="avatar" />` : ''}
            @${escapeHtml(playlist.username)}
          </span>
          <time>${date}</time>
        </div>
        <div class="pending-actions">
          <button class="btn btn-approve" data-action="approve" data-id="${escapeHtml(playlist.id)}">✅ 승인</button>
          <button class="btn btn-reject" data-action="reject" data-id="${escapeHtml(playlist.id)}">❌ 반려</button>
          <a href="/p/${escapeHtml(playlist.id)}" target="_blank" class="btn btn-preview">👁️ 미리보기</a>
        </div>
      `;

      gridEl.appendChild(card);
    });

    gridEl.querySelectorAll('[data-action]').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const action = target.getAttribute('data-action') as 'approve' | 'reject';
        const id = target.getAttribute('data-id');
        if (!id) return;

        const label = action === 'approve' ? '승인' : '반려';

        if (!confirm(`이 플레이리스트를 ${label}하시겠습니까?`)) return;

        target.disabled = true;
        target.textContent = '처리 중...';

        try {
          const res = await fetch(`/api/admin/playlists/${id}/${action}`, {
            method: 'PUT',
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error || `${label}에 실패했습니다.`);
          }

          const card = gridEl?.querySelector(`[data-id="${id}"]`);
          if (card) {
            card.classList.add('card-processed');
            card.innerHTML = `
              <div class="processed-message">
                <span>${action === 'approve' ? '✅' : '❌'} ${label} 완료</span>
              </div>
            `;
            setTimeout(() => {
              card.remove();
              if (gridEl && gridEl.children.length === 0) {
                hideAll();
                if (emptyStateEl) emptyStateEl.style.display = 'block';
              }
            }, 1500);
          }
        } catch (err: unknown) {
          alert(err instanceof Error ? err.message : '처리 중 오류가 발생했습니다.');
          target.disabled = false;
          target.textContent = action === 'approve' ? '✅ 승인' : '❌ 반려';
        }
      });
    });
  }

  if (retryBtn) {
    retryBtn.addEventListener('click', loadPending);
  }

  loadPending();
});
</script>

<style>

.grid-1 {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-md);
  max-width: 800px;
}

.state-message {
  padding: var(--space-2xl) var(--space-xl);
  text-align: center;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-md);
}

.state-message p {
  color: var(--color-text-muted);
  font-size: 1.1rem;
}

.error-message {
  background: rgba(239, 68, 68, 0.05);
  border-color: rgba(239, 68, 68, 0.2);
}

.error-message p {
  color: var(--color-danger);
}

.admin-content :global(.btn) {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-sm) var(--space-lg);
  border-radius: var(--radius-md);
  font-weight: 600;
  font-size: 0.95rem;
  transition: all 0.15s;
  text-decoration: none;
  border: 1px solid var(--color-border);
  background: var(--color-bg);
  color: var(--color-text);
  cursor: pointer;
}

.admin-content :global(.btn:hover) {
  background: var(--color-bg-secondary);
  text-decoration: none;
}

.admin-content :global(.btn-primary) {
  background: var(--color-primary);
  color: white;
  border-color: var(--color-primary);
}

.admin-content :global(.btn-primary:hover) {
  background: var(--color-primary-hover);
  color: white;
}

/* Pending card — dynamic content (innerHTML), needs :global() */
.admin-content :global(.pending-card) {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.admin-content :global(.pending-header) {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--space-md);
}

.admin-content :global(.pending-title) {
  font-size: 1.2rem;
  font-weight: 700;
  line-height: 1.4;
  margin: 0;
}

.admin-content :global(.pending-title a) {
  color: var(--color-text);
  text-decoration: none;
}

.admin-content :global(.pending-title a:hover) {
  color: var(--color-primary);
}

.admin-content :global(.pending-description) {
  font-size: 0.9rem;
  color: var(--color-text-muted);
  line-height: 1.5;
  margin: var(--space-xs) 0 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.admin-content :global(.pending-meta) {
  display: flex;
  align-items: center;
  gap: var(--space-md);
  color: var(--color-text-muted);
  font-size: 0.85rem;
}

.admin-content :global(.pending-author) {
  display: flex;
  align-items: center;
  gap: var(--space-xs);
  font-weight: 500;
}

.admin-content :global(.avatar) {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  object-fit: cover;
}

.admin-content :global(.pending-actions) {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
  padding-top: var(--space-sm);
  border-top: 1px solid var(--color-border);
}

.admin-content :global(.btn-approve) {
  background: rgba(16, 185, 129, 0.1);
  color: var(--color-success, #10b981);
  border-color: rgba(16, 185, 129, 0.3);
}

.admin-content :global(.btn-approve:hover) {
  background: rgba(16, 185, 129, 0.2);
}

.admin-content :global(.btn-reject) {
  background: rgba(239, 68, 68, 0.1);
  color: var(--color-danger);
  border-color: rgba(239, 68, 68, 0.3);
}

.admin-content :global(.btn-reject:hover) {
  background: rgba(239, 68, 68, 0.2);
}

.admin-content :global(.btn-preview) {
  margin-left: auto;
}

.admin-content :global(.card-processed) {
  opacity: 0.6;
  transition: opacity 0.3s;
}

.admin-content :global(.processed-message) {
  text-align: center;
  padding: var(--space-md);
  font-weight: 600;
  font-size: 1rem;
}

@media (max-width: 640px) {
  .admin-content :global(.pending-actions) {
    flex-direction: column;
  }
  .admin-content :global(.pending-actions .btn) {
    width: 100%;
  }
  .admin-content :global(.btn-preview) {
    margin-left: 0;
  }
}
</style>
