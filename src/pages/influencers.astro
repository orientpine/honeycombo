---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import InfluencerCard from '../components/InfluencerCard.astro';

const influencers = await getCollection('influencers').catch((err: unknown) => {
  console.error('Failed to load collection:', err);
  return [];
});

const xInfluencers = influencers
  .filter((i: any) => i.data.platform === 'x')
  .sort((a: any, b: any) => a.data.name.localeCompare(b.data.name));

const threadsInfluencers = influencers
  .filter((i: any) => i.data.platform === 'threads')
  .sort((a: any, b: any) => a.data.name.localeCompare(b.data.name));

const youtubeInfluencers = influencers
  .filter((i: any) => i.data.platform === 'youtube')
  .sort((a: any, b: any) => a.data.name.localeCompare(b.data.name));
---

<BaseLayout title="추천 인플루언서 — HoneyCombo" description="기술 분야 주요 인플루언서 모음">
  <header class="page-header">
    <h1 class="page-title">⭐ 추천 인플루언서</h1>
    <p class="page-description">기술 분야 주요 인물들을 팔로우해 보세요</p>
  </header>

  {xInfluencers.length > 0 && (
    <section class="platform-section">
      <h2 class="platform-title">𝕏 X (Twitter)</h2>
      <div class="influencer-grid grid grid-2" data-testid="influencer-list-x">
        {xInfluencers.map((influencer: any) => (
          <InfluencerCard
            id={influencer.data.id}
            name={influencer.data.name}
            platform={influencer.data.platform}
            handle={influencer.data.handle}
            bio={influencer.data.bio}
          />
        ))}
      </div>
    </section>
  )}

  {threadsInfluencers.length > 0 && (
    <section class="platform-section">
      <h2 class="platform-title">@ Threads</h2>
      <div class="influencer-grid grid grid-2" data-testid="influencer-list-threads">
        {threadsInfluencers.map((influencer: any) => (
          <InfluencerCard
            id={influencer.data.id}
            name={influencer.data.name}
            platform={influencer.data.platform}
            handle={influencer.data.handle}
            bio={influencer.data.bio}
          />
        ))}
      </div>
    </section>
  )}

  {youtubeInfluencers.length > 0 && (
    <section class="platform-section">
      <h2 class="platform-title">▶ YouTube</h2>
      <div class="influencer-grid grid grid-2" data-testid="influencer-list-youtube">
        {youtubeInfluencers.map((influencer: any) => (
          <InfluencerCard
            id={influencer.data.id}
            name={influencer.data.name}
            platform={influencer.data.platform}
            handle={influencer.data.handle}
            bio={influencer.data.bio}
          />
        ))}
      </div>
    </section>
  )}

  {xInfluencers.length === 0 && threadsInfluencers.length === 0 && youtubeInfluencers.length === 0 && (
    <p class="empty-state">추천 인플루언서를 준비 중입니다.</p>
  )}
</BaseLayout>

<style>
.platform-section { margin-bottom: var(--space-xl); }
.platform-title { font-size: 1.4rem; font-weight: 700; margin-bottom: var(--space-md); }
.empty-state { text-align: center; padding: var(--space-2xl); color: var(--color-text-muted); }
</style>
