---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="내 플레이리스트 — HoneyCombo" description="내가 만든 플레이리스트를 관리하세요">
  <header class="page-header flex-between">
    <div>
      <h1 class="page-title">📋 내 플레이리스트</h1>
      <p class="page-description">내가 만든 플레이리스트를 관리하세요</p>
    </div>
    <div class="header-actions" id="header-actions">
      <a href="/p/new" class="btn btn-primary">새 플레이리스트 만들기</a>
    </div>
  </header>

  <div class="my-playlists-content">
    <div id="auth-check-loading" class="state-message">
      <p>목록을 불러오는 중입니다...</p>
    </div>

    <div id="auth-required" class="state-message" style="display: none;">
      <p>플레이리스트를 관리하려면 로그인이 필요합니다.</p>
      <a href="/api/auth/github/login" class="btn btn-primary">GitHub로 로그인</a>
    </div>

    <div id="empty-state" class="state-message" style="display: none;">
      <p>아직 플레이리스트가 없습니다. 첫 플레이리스트를 만들어보세요!</p>
      <a href="/p/new" class="btn btn-primary">새 플레이리스트 만들기</a>
    </div>

    <div id="error-state" class="state-message error-message" style="display: none;">
      <p id="error-text">목록을 불러오는데 실패했습니다.</p>
      <button id="retry-btn" class="btn">다시 시도</button>
    </div>

    <div id="playlists-grid" class="grid grid-2" style="display: none;">
      <!-- Playlists will be rendered here -->
    </div>
  </div>
</BaseLayout>

<script>
document.addEventListener('astro:page-load', () => {
  const loadingEl = document.getElementById('auth-check-loading');
  const authRequiredEl = document.getElementById('auth-required');
  const emptyStateEl = document.getElementById('empty-state');
  const errorStateEl = document.getElementById('error-state');
  const errorTextEl = document.getElementById('error-text');
  const gridEl = document.getElementById('playlists-grid');
  const retryBtn = document.getElementById('retry-btn');

  let isAuthed = false;

  interface PlaylistListItem {
    id: string;
    title: string;
    description?: string | null;
    tags?: unknown;
    item_count?: number;
    created_at?: string;
    updated_at?: string;
    playlist_type?: 'community' | 'editor' | string;
    visibility?: 'public' | 'unlisted';
    status?: 'draft' | 'pending' | 'approved' | 'rejected';
    is_auto_created?: number | boolean | null;
    playlist_category?: string | null;
  }

  function isReadLaterPlaylist(playlist: PlaylistListItem) {
    return playlist.playlist_category === 'read_later'
      || (Number(playlist.is_auto_created ?? 0) === 1 && playlist.playlist_category === 'read_later');
  }

  async function checkAuthAndLoad() {
    hideAllStates();
    if (loadingEl) loadingEl.style.display = 'block';

    try {
      const res = await fetch('/api/auth/me');
      if (res.ok) {
        const userData = await res.json();
        isAuthed = true;
        if (userData.is_admin) {
          const headerActions = document.getElementById('header-actions');
          if (headerActions) {
            const editorBtn = document.createElement('a');
            editorBtn.href = '/p/new?type=editor';
            editorBtn.className = 'btn btn-secondary';
            editorBtn.textContent = '새 에디터 플레이리스트';
            headerActions.insertBefore(editorBtn, headerActions.firstChild);
          }
        }
        await loadPlaylists();
      } else {
        isAuthed = false;
        hideAllStates();
        if (authRequiredEl) authRequiredEl.style.display = 'block';
      }
    } catch (err) {
      isAuthed = false;
      hideAllStates();
      if (authRequiredEl) authRequiredEl.style.display = 'block';
    }
  }

  async function loadPlaylists() {
    try {
      const res = await fetch('/api/playlists?mine=true');
      if (!res.ok) {
        throw new Error('플레이리스트를 불러오는데 실패했습니다.');
      }

      const data = await res.json();
      const playlists: PlaylistListItem[] = Array.isArray(data.playlists) ? data.playlists : [];

      hideAllStates();

      if (playlists.length === 0) {
        if (emptyStateEl) emptyStateEl.style.display = 'block';
      } else {
        renderPlaylists(playlists);
        if (gridEl) gridEl.style.display = 'grid';
      }
    } catch (err: unknown) {
      hideAllStates();
      if (errorStateEl) errorStateEl.style.display = 'block';
      if (errorTextEl) {
        errorTextEl.textContent = err instanceof Error ? err.message : '알 수 없는 오류가 발생했습니다.';
      }
    }
  }

  function renderPlaylists(playlists: PlaylistListItem[]) {
    if (!gridEl) return;
    
    gridEl.innerHTML = '';
    
    playlists.forEach(playlist => {
      const isReadLater = isReadLaterPlaylist(playlist);
      const card = document.createElement('div');
      card.className = `card playlist-card${isReadLater ? ' playlist-card-read-later' : ''}`;
      
      const formattedDate = new Date(playlist.updated_at || playlist.created_at).toLocaleDateString('ko-KR', { 
        year: 'numeric', 
        month: 'short', 
        day: 'numeric' 
      });

      const isEditor = playlist.playlist_type === 'editor';
      const isPublic = playlist.visibility === 'public' || isEditor;
      const visibilityIcon = isPublic ? '🌐' : '🔒';
      const visibilityText = isPublic ? '공개' : '비공개';
      const visibilityClass = isPublic ? 'badge-public' : 'badge-unlisted';
      const safeId = escapeHtml(playlist.id);
      const safeTitle = escapeHtml(playlist.title || '제목 없음');
      const safeDescription = typeof playlist.description === 'string' ? playlist.description : '';
      let statusBadgeHtml = '';
      if (isPublic && !isReadLater) {
        const status = playlist.status || 'draft';
        let statusText = '';
        let statusClass = '';
        
        if (status === 'draft') {
          statusText = '작성 중';
          statusClass = 'badge-draft';
        } else if (status === 'pending') {
          statusText = '승인 대기';
          statusClass = 'badge-pending';
        } else if (status === 'approved') {
          statusText = '승인됨';
          statusClass = 'badge-approved';
        } else if (status === 'rejected') {
          statusText = '반려';
          statusClass = 'badge-rejected';
        }

        statusBadgeHtml = `<span class="badge ${statusClass}">${statusText}</span>`;
      }

      let visibilityActionHtml = '';
      if (!isEditor && !isReadLater) {
        if (!isPublic || playlist.status === 'draft') {
          visibilityActionHtml = `<button class="btn btn-sm visibility-btn visibility-btn-public" data-id="${safeId}" data-visibility="public">🌐 공개 신청</button>`;
        } else if (playlist.status === 'approved') {
          visibilityActionHtml = `<button class="btn btn-sm visibility-btn visibility-btn-unlisted" data-id="${safeId}" data-visibility="unlisted">🔒 비공개로 전환</button>`;
        } else if (playlist.status === 'rejected') {
          visibilityActionHtml = `<button class="btn btn-sm visibility-btn visibility-btn-public" data-id="${safeId}" data-visibility="public">🔄 재신청</button>`;
        }
      }

      const badgesHtml = isReadLater
        ? '<span class="badge badge-read-later">🔖 나중에 볼 기사</span>'
        : `
            <span class="badge ${visibilityClass}">${visibilityIcon} ${visibilityText}</span>
            ${statusBadgeHtml}
          `;
      const deleteActionHtml = isReadLater
        ? ''
        : `<button class="btn-icon delete-btn" data-id="${safeId}" aria-label="삭제" title="삭제">🗑️</button>`;

      card.innerHTML = `
        <div class="playlist-header">
          <h3 class="playlist-title">
            <a href="/p/${encodeURIComponent(playlist.id)}">${safeTitle}</a>
            ${isEditor ? '<span class="badge badge-editor">🏷️ 에디터</span>' : ''}
          </h3>
          <div class="playlist-actions">
            ${deleteActionHtml}
          </div>
        </div>
        
        ${safeDescription ? `<p class="playlist-description">${escapeHtml(safeDescription)}</p>` : ''}
        
        ${renderTags(playlist.tags)}
        
        <div class="playlist-meta">
          <div class="badges">
            ${badgesHtml}
          </div>
          <span class="playlist-count">${playlist.item_count || 0}개 항목</span>
        </div>
        
        <div class="playlist-footer">
          <time class="playlist-date">업데이트: ${formattedDate}</time>
          ${visibilityActionHtml}
        </div>
      `;
      
      gridEl.appendChild(card);
    });

    // Add delete event listeners
    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const id = target.getAttribute('data-id');
        if (!id) return;
        
        if (confirm('정말로 이 플레이리스트를 삭제하시겠습니까? 이 작업은 되돌릴 수 없습니다.')) {
          target.disabled = true;
          target.style.opacity = '0.5';
          
          try {
            const res = await fetch(`/api/playlists/${id}`, {
              method: 'DELETE'
            });
            
            if (res.ok) {
              await loadPlaylists();
            } else {
              const data = await res.json().catch(() => ({}));
              alert(data.error || '삭제에 실패했습니다.');
              target.disabled = false;
              target.style.opacity = '1';
            }
          } catch (err) {
            alert('삭제 중 오류가 발생했습니다.');
            target.disabled = false;
            target.style.opacity = '1';
          }
        }
      });
    });

    // Add visibility toggle event listeners
    document.querySelectorAll('.visibility-btn').forEach(btn => {
      btn.addEventListener('click', async (e) => {
        const target = e.currentTarget as HTMLButtonElement;
        const id = target.getAttribute('data-id');
        const visibility = target.getAttribute('data-visibility');
        if (!id || !visibility) return;

        const label = visibility === 'public' ? '공개 신청' : '비공개 전환';
        if (!confirm(`이 플레이리스트를 ${label}하시겠습니까?${visibility === 'public' ? '\n에디터 승인 후 공개됩니다.' : ''}`)) return;

        target.disabled = true;
        const originalText = target.textContent || '';
        target.textContent = '처리 중...';

        try {
          const res = await fetch(`/api/playlists/${id}/visibility`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ visibility })
          });

          if (!res.ok) {
            const data = await res.json().catch(() => ({}));
            throw new Error(data.error || `${label}에 실패했습니다.`);
          }

          await loadPlaylists();
        } catch (err) {
          alert(err instanceof Error ? err.message : '처리 중 오류가 발생했습니다.');
          target.disabled = false;
          target.textContent = originalText;
        }
      });
    });
  }

  function hideAllStates() {
    if (loadingEl) loadingEl.style.display = 'none';
    if (authRequiredEl) authRequiredEl.style.display = 'none';
    if (emptyStateEl) emptyStateEl.style.display = 'none';
    if (errorStateEl) errorStateEl.style.display = 'none';
    if (gridEl) gridEl.style.display = 'none';
  }

  function escapeHtml(unsafe: string) {
    return unsafe
         .replace(/&/g, "&amp;")
         .replace(/</g, "&lt;")
         .replace(/>/g, "&gt;")
         .replace(/"/g, "&quot;")
         .replace(/'/g, "&#039;");
  }

  function renderTags(tagsData: unknown) {
    if (!tagsData) return '';
    let tags: string[] = [];
    if (typeof tagsData === 'string') {
      try {
        tags = JSON.parse(tagsData);
      } catch (e) {
        return '';
      }
    } else if (Array.isArray(tagsData)) {
      tags = tagsData;
    }
    if (!tags || tags.length === 0) return '';
    
    return `<div class="playlist-tags">
      ${tags.map(t => `<span class="tag">${escapeHtml(t)}</span>`).join('')}
    </div>`;
  }

  if (retryBtn) {
    retryBtn.addEventListener('click', loadPlaylists);
  }

  // Initial load
  checkAuthAndLoad();
});
</script>

<style>

.flex-between {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  flex-wrap: wrap;
  gap: var(--space-md);
}

.header-actions {
  display: flex;
  gap: var(--space-sm);
  flex-wrap: wrap;
}

.state-message {
  padding: var(--space-2xl) var(--space-xl);
  text-align: center;
  background: var(--color-bg-secondary);
  border-radius: var(--radius-md);
  border: 1px solid var(--color-border);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-md);
}

.state-message p {
  color: var(--color-text-muted);
  font-size: 1.1rem;
}

.error-message {
  background: rgba(239, 68, 68, 0.05);
  border-color: rgba(239, 68, 68, 0.2);
}

.error-message p {
  color: var(--color-danger);
}

/* Buttons — used in both static and dynamic content */
.my-playlists-content :global(.btn),
.header-actions :global(.btn) {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-sm) var(--space-lg);
  border-radius: var(--radius-md);
  font-weight: 600;
  font-size: 0.95rem;
  transition:
    transform 0.2s cubic-bezier(0.4, 0, 0.2, 1),
    background 0.2s cubic-bezier(0.4, 0, 0.2, 1),
    border-color 0.2s cubic-bezier(0.4, 0, 0.2, 1),
    box-shadow 0.2s cubic-bezier(0.4, 0, 0.2, 1),
    color 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  text-decoration: none;
  border: 1px solid var(--color-border);
  background: var(--color-bg);
  color: var(--color-text);
  cursor: pointer;
}

.my-playlists-content :global(.btn:hover),
.header-actions :global(.btn:hover) {
  background: var(--color-bg-secondary);
  transform: translateY(-1px);
  box-shadow: var(--shadow-sm);
}

.my-playlists-content :global(.btn:focus-visible),
.header-actions :global(.btn:focus-visible) {
  outline: none;
  border-color: var(--color-primary);
  box-shadow:
    0 0 0 2px var(--color-bg),
    0 0 0 4px var(--color-primary);
}

.my-playlists-content :global(.btn-primary),
.header-actions :global(.btn-primary) {
  background: var(--color-primary);
  color: white;
  border-color: var(--color-primary);
}

.my-playlists-content :global(.btn-primary:hover),
.header-actions :global(.btn-primary:hover) {
  background: var(--color-primary-hover);
  color: white;
  text-decoration: none;
}

.header-actions :global(.btn-secondary) {
  background: var(--color-bg-secondary);
  color: var(--color-text);
  border-color: var(--color-border);
}

.header-actions :global(.btn-secondary:hover) {
  background: var(--color-border);
}

/* Playlist Card Styles — dynamic content (innerHTML), needs :global() */
.my-playlists-content :global(.playlist-card) {
  display: flex;
  flex-direction: column;
  gap: var(--space-md);
}

.my-playlists-content :global(.playlist-card-read-later) {
  border-left: 3px solid var(--color-primary);
  background: linear-gradient(135deg, var(--color-bg-secondary), var(--color-bg));
  box-shadow: var(--shadow-sm);
}

.my-playlists-content :global(.playlist-header) {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: var(--space-sm);
}

.my-playlists-content :global(.playlist-title) {
  font-size: 1.2rem;
  font-weight: 700;
  line-height: 1.4;
  margin: 0;
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  flex-wrap: wrap;
}

.my-playlists-content :global(.playlist-title a) {
  color: var(--color-text);
  text-decoration: none;
}

.my-playlists-content :global(.playlist-title a:hover) {
  color: var(--color-primary);
}

.my-playlists-content :global(.playlist-description) {
  font-size: 0.9rem;
  color: var(--color-text-muted);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin: 0;
}

.my-playlists-content :global(.playlist-meta) {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.my-playlists-content :global(.badges) {
  display: flex;
  gap: var(--space-xs);
  flex-wrap: wrap;
}

.my-playlists-content :global(.badge-unlisted) {
  background: var(--color-bg-secondary);
  color: var(--color-text-muted);
  border-color: var(--color-border);
}

.my-playlists-content :global(.badge-public) {
  background: rgba(37, 99, 235, 0.1);
  color: var(--color-primary);
  border-color: rgba(37, 99, 235, 0.2);
}

.my-playlists-content :global(.badge-draft) {
  background: var(--color-bg-secondary);
  color: var(--color-text-muted);
}

.my-playlists-content :global(.badge-pending) {
  background: rgba(245, 158, 11, 0.1);
  color: #d97706;
  border-color: rgba(245, 158, 11, 0.2);
}

.my-playlists-content :global(.badge-approved) {
  background: rgba(16, 185, 129, 0.1);
  color: var(--color-success);
  border-color: rgba(16, 185, 129, 0.2);
}

.my-playlists-content :global(.badge-rejected) {
  background: rgba(239, 68, 68, 0.1);
  color: var(--color-danger);
  border-color: rgba(239, 68, 68, 0.2);
}

.my-playlists-content :global(.badge-editor) {
  background: rgba(245, 158, 11, 0.1);
  color: #d97706;
  border-color: rgba(245, 158, 11, 0.2);
}

.my-playlists-content :global(.badge-read-later) {
  background: var(--color-bg-secondary);
  color: var(--color-primary);
  border-color: var(--color-primary);
  text-transform: none;
  letter-spacing: 0.02em;
}

.my-playlists-content :global(.playlist-tags) {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-xs);
}

.my-playlists-content :global(.tag) {
  font-size: 0.75rem;
  padding: 2px 8px;
  background: var(--color-bg-secondary);
  color: var(--color-text-muted);
  border-radius: 999px;
  border: 1px solid var(--color-border);
}

.my-playlists-content :global(.playlist-count) {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--color-text);
  background: var(--color-bg-secondary);
  padding: 2px var(--space-sm);
  border-radius: var(--radius-sm);
}

.my-playlists-content :global(.playlist-footer) {
  margin-top: auto;
  padding-top: var(--space-sm);
  border-top: 1px solid var(--color-border);
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--space-sm);
}

.my-playlists-content :global(.playlist-date) {
  font-size: 0.8rem;
  color: var(--color-text-muted);
}

.my-playlists-content :global(.btn-icon) {
  background: none;
  border: none;
  font-size: 1.2rem;
  cursor: pointer;
  padding: var(--space-xs);
  border-radius: var(--radius-sm);
  transition:
    transform 0.2s cubic-bezier(0.4, 0, 0.2, 1),
    background 0.2s cubic-bezier(0.4, 0, 0.2, 1),
    opacity 0.2s cubic-bezier(0.4, 0, 0.2, 1),
    box-shadow 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  display: flex;
  align-items: center;
  justify-content: center;
  opacity: 0.6;
}

.my-playlists-content :global(.btn-icon:hover) {
  background: var(--color-bg-secondary);
  opacity: 1;
  transform: translateY(-1px);
}

.my-playlists-content :global(.btn-icon:focus-visible) {
  outline: none;
  opacity: 1;
  box-shadow:
    0 0 0 2px var(--color-bg),
    0 0 0 4px var(--color-primary);
}

.my-playlists-content :global(.delete-btn:hover) {
  background: rgba(239, 68, 68, 0.1);
}

.my-playlists-content :global(.visibility-btn) {
  padding: var(--space-xs) var(--space-sm);
  font-size: 0.8rem;
  font-weight: 500;
  border-radius: var(--radius-sm);
  cursor: pointer;
  transition:
    transform 0.2s cubic-bezier(0.4, 0, 0.2, 1),
    background 0.2s cubic-bezier(0.4, 0, 0.2, 1),
    border-color 0.2s cubic-bezier(0.4, 0, 0.2, 1),
    box-shadow 0.2s cubic-bezier(0.4, 0, 0.2, 1),
    color 0.2s cubic-bezier(0.4, 0, 0.2, 1);
  border: 1px solid var(--color-border);
  background: var(--color-bg);
  color: var(--color-text);
}

.my-playlists-content :global(.visibility-btn-public) {
  background: rgba(37, 99, 235, 0.1);
  color: var(--color-primary);
  border-color: rgba(37, 99, 235, 0.2);
}

.my-playlists-content :global(.visibility-btn-public:hover:not(:disabled)) {
  background: rgba(37, 99, 235, 0.2);
  transform: translateY(-1px);
  box-shadow: var(--shadow-sm);
}

.my-playlists-content :global(.visibility-btn-unlisted) {
  background: var(--color-bg-secondary);
  color: var(--color-text-muted);
}

.my-playlists-content :global(.visibility-btn-unlisted:hover:not(:disabled)) {
  background: var(--color-bg-secondary);
  border-color: var(--color-text-muted);
  transform: translateY(-1px);
  box-shadow: var(--shadow-sm);
}

.my-playlists-content :global(.visibility-btn:focus-visible) {
  outline: none;
  border-color: var(--color-primary);
  box-shadow:
    0 0 0 2px var(--color-bg),
    0 0 0 4px var(--color-primary);
}

.my-playlists-content :global(.visibility-btn:disabled) {
  opacity: 0.6;
  cursor: not-allowed;
}

@media (max-width: 640px) {
  .flex-between {
    flex-direction: column;
  }
  .flex-between :global(.btn) {
    width: 100%;
  }
}
</style>
