---
const year = new Date().getFullYear();
---

<footer data-testid="footer" class="footer">
  <div class="container footer-inner">
    <p class="footer-copy">© {year} HoneyCombo — 기술 뉴스 큐레이션</p>
    <div class="footer-links">
      <a href="/rss.xml" aria-label="RSS 피드">RSS</a>
      <a href="https://github.com/orientpine/honeycombo" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </div>
</footer>

<style>
.footer {
  border-top: 1px solid var(--color-border);
  padding: var(--space-lg) 0;
  margin-top: var(--space-2xl);
}
.footer-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: var(--space-sm);
}
.footer-copy { color: var(--color-text-muted); font-size: 0.875rem; }
.footer-links { display: flex; gap: var(--space-md); }
.footer-links a { color: var(--color-text-muted); font-size: 0.875rem; }
.footer-links a:hover { color: var(--color-primary); }
</style>