---
interface Props {
  articleId: string;
  rank: number;
}

const { articleId, rank } = Astro.props;

// Try to load article data
import { getCollection } from 'astro:content';
const allCurated = await getCollection('curated', e => e.data.status === 'approved');
const allFeeds = await getCollection('feeds');

const article = allCurated.find(e => e.id === articleId) || allFeeds.find(e => e.id === articleId);
const data = article?.data;
---

{data ? (
  <article class="card must-read-card" data-testid="must-read-card">
    <div class="must-read-rank">#{rank}</div>
    <div class="must-read-body">
      <h3 class="must-read-title">
        <a href={data.url} target="_blank" rel="noopener noreferrer">{data.title}</a>
      </h3>
      <div class="must-read-meta">
        <span class="badge">{data.source}</span>
        <div class="must-read-tags">
          {data.tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
        </div>
      </div>
    </div>
  </article>
) : (
  <div class="must-read-placeholder" data-testid="must-read-placeholder">
    기사 정보를 불러올 수 없습니다.
  </div>
)}

<style>
.must-read-card { display: flex; gap: var(--space-md); align-items: flex-start; }
.must-read-rank { font-size: 1.5rem; font-weight: 800; color: var(--color-accent); min-width: 2rem; }
.must-read-body { flex: 1; }
.must-read-title { font-size: 1rem; font-weight: 600; margin-bottom: var(--space-sm); }
.must-read-title a { color: var(--color-text); }
.must-read-title a:hover { color: var(--color-primary); text-decoration: none; }
.must-read-meta { display: flex; align-items: center; gap: var(--space-sm); flex-wrap: wrap; }
.must-read-tags { display: flex; gap: var(--space-xs); flex-wrap: wrap; }
.must-read-placeholder { color: var(--color-text-muted); font-size: 0.875rem; padding: var(--space-sm); }
</style>
