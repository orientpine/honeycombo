---
const navItems = [
  { href: '/', label: 'Home' },
  { href: '/articles', label: 'Articles' },
  { href: '/trending', label: 'Trending' },
  { href: '/must-read', label: 'Must-read' },
  { href: '/playlists', label: 'Playlists' },
  { href: '/community', label: 'Community' },
  { href: '/influencers', label: 'Influencers' },
  { href: '/submit', label: 'Submit' },
];

const currentPath = Astro.url.pathname;
---

<nav data-testid="nav-main" class="nav" transition:persist>
  <div class="container nav-inner">
    <a href="/" class="nav-logo">HONEYCOMBO</a>
    <button class="nav-toggle" id="nav-toggle" aria-label="메뉴 열기" aria-expanded="false">
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
      <span class="nav-toggle-bar"></span>
    </button>
    <ul class="nav-links" id="nav-links">
      {navItems.map(item => (
        <li>
          <a
            href={item.href}
            class:list={['nav-link', { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
    <div id="auth-area" class="auth-area"><a href="/api/auth/github/login" class="auth-login-btn">로그인</a></div>
  </div>
</nav>

<!-- Pre-paint: render cached auth state synchronously before first paint.
     Astro deferred scripts run AFTER paint; this inline script runs BEFORE. -->
<script is:inline>
(function() {
  var KEY = 'honeycombo:auth';
  var raw;
  try { raw = sessionStorage.getItem(KEY); } catch(e) { return; }
  if (!raw || raw === 'guest') return; // Server-rendered login button is correct
  var user;
  try { user = JSON.parse(raw); } catch(e) {
    try { sessionStorage.removeItem(KEY); } catch(e2) {}
    return;
  }
  var el = document.getElementById('auth-area');
  if (!el) return;
  function esc(s) {
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  var avatar = (user.avatar_url && user.avatar_url.indexOf('https://') === 0) ? esc(user.avatar_url) : '/default-avatar.png';
  var name = esc(user.username || '');
  el.innerHTML =
    '<div class="auth-user">' +
    '<img src="' + avatar + '" alt="' + name + '" class="auth-avatar" />' +
    '<span class="auth-username">' + name + '</span>' +
    '<div class="auth-dropdown">' +
    '<a href="/my/playlists" class="auth-dropdown-item">내 플레이리스트</a>' +
    (user.is_admin ? '<a href="/admin/must-read" class="auth-dropdown-item auth-dropdown-admin">⭐ Must-read 관리</a><a href="/admin/playlists" class="auth-dropdown-item auth-dropdown-admin">🛡️ 플레이리스트 관리</a><a href="/admin" class="auth-dropdown-item auth-dropdown-admin">🛡️ 기사 검토 (CMS)</a>' : '') +
    '<button class="auth-dropdown-item text-danger auth-logout-btn">로그아웃</button>' +
    '</div>' +
    '</div>';
})();
</script>

<script>
const AUTH_CACHE_KEY = 'honeycombo:auth';

function escapeHtml(str: string): string {
  return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

function toAuthCache(user: any): { username: string; avatar_url: string; is_admin: boolean } {
  return { username: String(user.username || ''), avatar_url: String(user.avatar_url || ''), is_admin: !!user.is_admin };
}

function renderAuthUser(authArea: HTMLElement, user: { username: string; avatar_url: string; is_admin: boolean }) {
  const avatarUrl = user.avatar_url.startsWith('https://') ? escapeHtml(user.avatar_url) : '/default-avatar.png';
  const safeName = escapeHtml(user.username);
  authArea.innerHTML =
    '<div class="auth-user">' +
    '<img src="' + avatarUrl + '" alt="' + safeName + '" class="auth-avatar" />' +
    '<span class="auth-username">' + safeName + '</span>' +
    '<div class="auth-dropdown">' +
    '<a href="/my/playlists" class="auth-dropdown-item">내 플레이리스트</a>' +
    (user.is_admin ? '<a href="/admin/must-read" class="auth-dropdown-item auth-dropdown-admin">⭐ Must-read 관리</a><a href="/admin/playlists" class="auth-dropdown-item auth-dropdown-admin">🛡️ 플레이리스트 관리</a><a href="/admin" class="auth-dropdown-item auth-dropdown-admin">🛡️ 기사 검토 (CMS)</a>' : '') +
    '<button class="auth-dropdown-item text-danger auth-logout-btn">로그아웃</button>' +
    '</div>' +
    '</div>';
}

function renderLoginBtn(authArea: HTMLElement) {
  authArea.innerHTML = '<a href="/api/auth/github/login" class="auth-login-btn">로그인</a>';
}

function bindLogout(authArea: HTMLElement) {
  const logoutBtn = authArea.querySelector<HTMLButtonElement>('.auth-logout-btn');
  if (logoutBtn) {
    logoutBtn.addEventListener('click', async () => {
      try { sessionStorage.removeItem(AUTH_CACHE_KEY); } catch (_) {}
      await fetch('/api/auth/logout', { method: 'POST' });
      window.location.reload();
    });
  }
}

// Initial setup — runs once (nav persists via transition:persist)
const navToggle = document.getElementById('nav-toggle');
if (navToggle) {
  navToggle.addEventListener('click', () => {
    const links = document.getElementById('nav-links');
    if (links) {
      const isOpen = links.classList.toggle('open');
      navToggle.classList.toggle('open', isOpen);
      navToggle.setAttribute('aria-expanded', String(isOpen));
    }
  });
}

const authArea = document.getElementById('auth-area');
if (authArea) bindLogout(authArea);

// Update active nav link on client-side navigation (nav persists, active state is stale)
document.addEventListener('astro:after-swap', () => {
  const currentPath = window.location.pathname;
  document.querySelectorAll<HTMLAnchorElement>('.nav-link').forEach(link => {
    const href = link.getAttribute('href');
    const isActive = href === currentPath || (href !== '/' && href !== null && currentPath.startsWith(href));
    link.classList.toggle('active', isActive);
  });
});

// Background auth verify on every navigation
document.addEventListener('astro:page-load', () => {
  const authArea = document.getElementById('auth-area');
  if (!authArea) return;

  let cachedRaw: string | null = null;
  try { cachedRaw = sessionStorage.getItem(AUTH_CACHE_KEY); } catch (_) {}

  fetch('/api/auth/me').then(async (res) => {
    if (res.ok) {
      const user = await res.json();
      const fresh = JSON.stringify(toAuthCache(user));
      if (fresh !== cachedRaw) {
        renderAuthUser(authArea, toAuthCache(user));
        bindLogout(authArea);
        try { sessionStorage.setItem(AUTH_CACHE_KEY, fresh); } catch (_) {}
      }
    } else if (res.status === 401) {
      if (cachedRaw !== 'guest') {
        renderLoginBtn(authArea);
        try { sessionStorage.setItem(AUTH_CACHE_KEY, 'guest'); } catch (_) {}
      }
    }
  }).catch(() => {});
});
</script>

<style>
.nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--color-bg);
  border-bottom: 2px solid transparent;
  border-image: linear-gradient(to right, var(--color-primary), var(--color-accent)) 1;
  height: var(--nav-height);
}
.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
}
.nav-logo {
  font-size: 1.2rem;
  font-weight: 900;
  letter-spacing: 0.05em;
  background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-accent) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  text-decoration: none;
}
.nav-logo:hover { filter: brightness(1.1); }
.nav-toggle {
  display: none;
  flex-direction: column;
  gap: 4px;
  background: none;
  border: none;
  cursor: pointer;
  padding: var(--space-xs);
}
.nav-toggle-bar {
  display: block;
  width: 20px;
  height: 2px;
  background: var(--color-text);
  border-radius: 1px;
  transition: transform 0.2s, opacity 0.2s;
}
.nav-toggle.open .nav-toggle-bar:nth-child(1) { transform: translateY(6px) rotate(45deg); }
.nav-toggle.open .nav-toggle-bar:nth-child(2) { opacity: 0; }
.nav-toggle.open .nav-toggle-bar:nth-child(3) { transform: translateY(-6px) rotate(-45deg); }
.nav-links {
  display: flex;
  list-style: none;
  gap: var(--space-sm);
}
.nav-link {
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-sm);
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--color-text-muted);
  text-decoration: none;
  transition: background 0.15s, color 0.15s;
}
.nav-link:hover { background: var(--color-bg-secondary); color: var(--color-text); text-decoration: none; }
.nav-link.active { background: var(--color-primary); color: white; }
.auth-area {
  display: flex;
  align-items: center;
}
.auth-area :global(.auth-user) {
  position: relative;
  display: flex;
  align-items: center;
  gap: var(--space-sm);
  cursor: pointer;
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-sm);
  transition: background 0.15s;
}
.auth-area :global(.auth-user:hover) {
  background: var(--color-bg-secondary);
}
.auth-area :global(.auth-user::after) {
  content: '';
  position: absolute;
  left: 0;
  right: 0;
  top: 100%;
  height: var(--space-xs);
}
.auth-area :global(.auth-avatar) {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  object-fit: cover;
}
.auth-area :global(.auth-username) {
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--color-text);
}
.auth-area :global(.auth-dropdown) {
  position: absolute;
  top: 100%;
  right: 0;
  margin-top: var(--space-xs);
  background: var(--color-bg);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-md);
  min-width: 150px;
  display: none;
  flex-direction: column;
  padding: var(--space-xs) 0;
  z-index: 10;
}
.auth-area :global(.auth-user:hover .auth-dropdown) {
  display: flex;
}
.auth-area :global(.auth-dropdown-item) {
  padding: var(--space-sm) var(--space-md);
  font-size: 0.9rem;
  color: var(--color-text);
  text-decoration: none;
  background: none;
  border: none;
  text-align: left;
  cursor: pointer;
  width: 100%;
}
.auth-area :global(.auth-dropdown-item:hover) {
  background: var(--color-bg-secondary);
  text-decoration: none;
}
.auth-area :global(.auth-dropdown-item.text-danger) {
  color: var(--color-danger);
}
.auth-area :global(.auth-dropdown-admin) {
  border-top: 1px solid var(--color-border);
  margin-top: var(--space-xs);
  padding-top: var(--space-sm);
  color: var(--color-primary);
  font-weight: 600;
}
.auth-area :global(.auth-login-btn) {
  padding: var(--space-xs) var(--space-md);
  background: var(--color-primary);
  color: white;
  border-radius: var(--radius-sm);
  font-size: 0.9rem;
  font-weight: 500;
  text-decoration: none;
  transition: background 0.15s;
}
.auth-area :global(.auth-login-btn:hover) {
  background: var(--color-primary-hover);
  color: white;
  text-decoration: none;
}

@media (max-width: 768px) {
  .nav { height: auto; min-height: var(--nav-height); }
  .nav-inner { flex-wrap: wrap; padding-top: var(--space-sm); padding-bottom: var(--space-sm); }
  .nav-toggle { display: flex; }
  .nav-links {
    display: none;
    flex-direction: column;
    width: 100%;
    padding-top: var(--space-sm);
    gap: 2px;
  }
  .nav-links.open { display: flex; }
  .nav-link { padding: var(--space-sm); }
  .auth-area {
    margin-left: auto;
    margin-right: var(--space-md);
  }
}
</style>
