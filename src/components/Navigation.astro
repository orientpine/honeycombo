---
const navItems = [
  { href: '/', label: '홈' },
  { href: '/articles', label: '기사' },
  { href: '/trending', label: '트렌드' },
  { href: '/must-read', label: 'Must-read' },
  { href: '/playlists', label: '플레이리스트' },
  { href: '/influencers', label: '인플루언서' },
  { href: '/submit', label: '자료등록' },
];

const currentPath = Astro.url.pathname;
---

<nav data-testid="nav-main" class="nav">
  <div class="container nav-inner">
    <a href="/" class="nav-logo">🍯 HoneyCombo</a>
    <ul class="nav-links">
      {navItems.map(item => (
        <li>
          <a 
            href={item.href} 
            class:list={['nav-link', { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
.nav {
  position: sticky;
  top: 0;
  z-index: 100;
  background: var(--color-bg);
  border-bottom: 1px solid var(--color-border);
  height: var(--nav-height);
}
.nav-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 100%;
}
.nav-logo {
  font-size: 1.2rem;
  font-weight: 700;
  color: var(--color-text);
  text-decoration: none;
}
.nav-logo:hover { color: var(--color-primary); }
.nav-links {
  display: flex;
  list-style: none;
  gap: var(--space-sm);
}
.nav-link {
  padding: var(--space-xs) var(--space-sm);
  border-radius: var(--radius-sm);
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--color-text-muted);
  text-decoration: none;
  transition: background 0.15s, color 0.15s;
}
.nav-link:hover { background: var(--color-bg-secondary); color: var(--color-text); text-decoration: none; }
.nav-link.active { background: var(--color-primary); color: white; }

@media (max-width: 768px) {
  .nav-links { display: none; }
}
</style>