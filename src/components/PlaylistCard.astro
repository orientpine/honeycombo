---
interface Props {
  id: string;
  title: string;
  description?: string;
  curator: string;
  tags: string[];
  itemCount: number;
  updatedAt: Date | string;
}

const { id, title, description, curator, tags, itemCount, updatedAt } = Astro.props;
const formattedDate = new Date(updatedAt).toLocaleDateString('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' });
---

<a href={`/playlists/${id}`} class="card playlist-card" data-testid="playlist-card">
  <div class="playlist-header">
    <h3 class="playlist-title">{title}</h3>
    <span class="playlist-count">{itemCount}개</span>
  </div>
  {description && <p class="playlist-description">{description}</p>}
  <div class="playlist-footer">
    <span class="playlist-curator">by {curator}</span>
    <time class="playlist-date">{formattedDate}</time>
  </div>
  <div class="playlist-tags">
    {tags.slice(0, 3).map(tag => <span class="tag">{tag}</span>)}
  </div>
</a>

<style>
.playlist-card { display: flex; flex-direction: column; gap: var(--space-sm); text-decoration: none; color: var(--color-text); }
.playlist-card:hover { text-decoration: none; }
.playlist-header { display: flex; justify-content: space-between; align-items: flex-start; }
.playlist-title { font-size: 1.1rem; font-weight: 700; }
.playlist-count { font-size: 0.8rem; color: var(--color-text-muted); background: var(--color-bg-secondary); padding: 2px var(--space-sm); border-radius: var(--radius-sm); }
.playlist-description { font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.5; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; }
.playlist-footer { display: flex; justify-content: space-between; align-items: center; }
.playlist-curator { font-size: 0.8rem; color: var(--color-text-muted); }
.playlist-date { font-size: 0.8rem; color: var(--color-text-muted); }
.playlist-tags { display: flex; flex-wrap: wrap; gap: var(--space-xs); }
</style>