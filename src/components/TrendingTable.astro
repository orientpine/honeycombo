---
interface TrendingItem {
  rank: number;
  keyword: string;
  score: number;
  direction: 'rising' | 'stable' | 'falling';
  velocity: number;
  article_count: number;
  top_articles: string[];
}

interface Props {
  items: TrendingItem[];
  week: string;
}

const { items, week } = Astro.props;

const directionIcon = (d: string) => {
  if (d === 'rising') return '🔥';
  if (d === 'falling') return '📉';
  return '➡️';
};
---

<div class="trending-table-wrapper" data-testid="trending-list">
  <div class="trending-header">
    <h2 class="trending-week">{week} 주간 트렌드</h2>
    <p class="trending-subtitle">최근 7일간 가장 많이 언급된 주제</p>
  </div>
  
  <ol class="trending-list">
    {items.map(item => (
      <li class="trending-item">
        <span class="trending-rank">#{item.rank}</span>
        <div class="trending-content">
          <span class="trending-keyword">
            {directionIcon(item.direction)} {item.keyword}
          </span>
          <span class="trending-count">{item.article_count}개 기사</span>
        </div>
        <span class="trending-score">{item.score.toFixed(1)}</span>
      </li>
    ))}
  </ol>
</div>

<style>
.trending-table-wrapper { background: var(--color-bg); border: 1px solid var(--color-border); border-radius: var(--radius-lg); overflow: hidden; }
.trending-header { padding: var(--space-lg); border-bottom: 1px solid var(--color-border); background: var(--color-bg-secondary); }
.trending-week { font-size: 1.1rem; font-weight: 700; }
.trending-subtitle { font-size: 0.875rem; color: var(--color-text-muted); margin-top: var(--space-xs); }
.trending-list { list-style: none; }
.trending-item { display: flex; align-items: center; gap: var(--space-md); padding: var(--space-md) var(--space-lg); border-bottom: 1px solid var(--color-border); transition: background 0.15s; }
.trending-item:last-child { border-bottom: none; }
.trending-item:hover { background: var(--color-bg-secondary); }
.trending-rank { font-size: 1.2rem; font-weight: 800; color: var(--color-text-muted); min-width: 2.5rem; }
.trending-content { flex: 1; display: flex; flex-direction: column; gap: 2px; }
.trending-keyword { font-size: 1rem; font-weight: 600; text-transform: capitalize; }
.trending-count { font-size: 0.8rem; color: var(--color-text-muted); }
.trending-score { font-size: 0.875rem; color: var(--color-text-muted); font-variant-numeric: tabular-nums; }
</style>
