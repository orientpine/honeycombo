---
interface Props {
  id: string;
  name: string;
  platform: string;
  handle: string;
  bio?: string;
}

const { id, name, platform, handle, bio } = Astro.props;

const platformIcon = (p: string) => {
  if (p === 'x') return '𝕏';
  if (p === 'youtube') return '▶';
  if (p === 'threads') return '@';
  return '🌐';
};

const handleClean = handle.replace(/^@/, '');
const profileUrl = platform === 'x' ? `https://x.com/${handleClean}` : '#';
---

<article class="card influencer-card" data-testid="influencer-card">
  <div class="influencer-header">
    <div class="influencer-info">
      <h3 class="influencer-name">
        <a href={profileUrl} target="_blank" rel="noopener noreferrer">{name}</a>
      </h3>
      <span class="influencer-handle">{platformIcon(platform)} {handle}</span>
    </div>
  </div>

  {bio && <p class="influencer-bio">{bio}</p>}

  <a href={profileUrl} target="_blank" rel="noopener noreferrer" class="profile-link">
    {platformIcon(platform)} {handle} 에서 보기 →
  </a>
</article>

<style>
.influencer-card { display: flex; flex-direction: column; gap: var(--space-md); }
.influencer-header { display: flex; justify-content: space-between; align-items: flex-start; }
.influencer-info { display: flex; flex-direction: column; gap: 2px; }
.influencer-name { font-size: 1.1rem; font-weight: 700; }
.influencer-name a { color: inherit; text-decoration: none; }
.influencer-name a:hover { color: var(--color-primary); text-decoration: underline; }
.influencer-handle { font-size: 0.875rem; color: var(--color-text-muted); }
.influencer-bio { font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.5; }
.profile-link {
  display: block;
  text-align: center;
  padding: var(--space-sm) var(--space-md);
  border: 1px solid var(--color-primary);
  border-radius: 8px;
  color: var(--color-primary);
  font-size: 0.9rem;
  font-weight: 600;
  text-decoration: none;
  transition: background 0.2s, color 0.2s;
}
.profile-link:hover {
  background: var(--color-primary);
  color: white;
  text-decoration: none;
}
</style>
