---
interface Props {
  id: string;
  name: string;
  platform: string;
  handle: string;
  bio?: string;
}

const { id, name, platform, handle, bio } = Astro.props;

const platformIcon = (p: string) => {
  if (p === 'x') return '𝕏';
  if (p === 'youtube') return '▶';
  if (p === 'threads') return '@';
  return '🌐';
};

const handleClean = handle.replace(/^@/, '');
const profileUrl = platform === 'x' ? `https://x.com/${handleClean}` : '#';
const syndicationUrl = `https://syndication.twitter.com/srv/timeline-profile/screen-name/${handleClean}`;
---

<article class="card influencer-card" data-testid="influencer-card">
  <div class="influencer-header">
    <div class="influencer-info">
      <h3 class="influencer-name">
        <a href={profileUrl} target="_blank" rel="noopener noreferrer">{name}</a>
      </h3>
      <span class="influencer-handle">{platformIcon(platform)} {handle}</span>
    </div>
    <a href={profileUrl} target="_blank" rel="noopener noreferrer" class="badge">{platform}</a>
  </div>

  {bio && <p class="influencer-bio">{bio}</p>}

  {platform === 'x' && (
    <div class="timeline-embed" data-src={syndicationUrl}>
      <button class="timeline-load-btn" type="button">
        𝕏 타임라인 보기
      </button>
    </div>
  )}
</article>

<script>
  document.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('.timeline-load-btn');
    if (!btn) return;
    const container = btn.closest('.timeline-embed') as HTMLElement;
    if (!container) return;
    const src = container.dataset.src;
    if (!src) return;
    container.innerHTML = `<iframe src="${src}" title="타임라인" loading="lazy" sandbox="allow-same-origin allow-scripts allow-popups allow-popups-to-escape-sandbox"></iframe>`;
  });
</script>

<style>
.influencer-card { display: flex; flex-direction: column; gap: var(--space-md); }
.influencer-header { display: flex; justify-content: space-between; align-items: flex-start; }
.influencer-info { display: flex; flex-direction: column; gap: 2px; }
.influencer-name { font-size: 1.1rem; font-weight: 700; }
.influencer-name a { color: inherit; text-decoration: none; }
.influencer-name a:hover { color: var(--color-primary); text-decoration: underline; }
.influencer-handle { font-size: 0.875rem; color: var(--color-text-muted); }
.influencer-bio { font-size: 0.875rem; color: var(--color-text-muted); line-height: 1.5; }
.timeline-embed { border-radius: 8px; overflow: hidden; }
.timeline-embed iframe { width: 100%; height: 500px; border: none; }
.timeline-load-btn {
  width: 100%;
  padding: var(--space-md);
  border: 1px dashed var(--color-text-muted);
  border-radius: 8px;
  background: transparent;
  color: var(--color-primary);
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  transition: background 0.2s, border-color 0.2s;
}
.timeline-load-btn:hover {
  background: var(--color-primary);
  color: white;
  border-color: var(--color-primary);
}
</style>
