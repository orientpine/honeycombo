---
interface Props {
  curatedCount: number;
  submittedCount: number;
  feedCount: number;
}
const { curatedCount, submittedCount, feedCount } = Astro.props;
---

<div class="source-filter" data-testid="source-filter">
  <button class="source-filter-btn active" data-origin="all" data-original-count={curatedCount + submittedCount + feedCount}>
    전체 <span class="source-count" data-count-for="all">{curatedCount + submittedCount + feedCount}</span>
  </button>
  <button class="source-filter-btn" data-origin="submitted" data-original-count={submittedCount}>
    제출 기사 <span class="source-count" data-count-for="submitted">{submittedCount}</span>
  </button>
  <button class="source-filter-btn" data-origin="feed" data-original-count={feedCount}>
    RSS 피드 <span class="source-count" data-count-for="feed">{feedCount}</span>
  </button>
</div>

<p class="source-filter-empty" data-testid="source-filter-empty" style="display:none;">
  이 페이지에 해당하는 기사가 없습니다.
</p>

<script>
function filterByOrigin(origin: string) {
  const buttons = document.querySelectorAll<HTMLElement>('[data-testid="source-filter"] .source-filter-btn');

  buttons.forEach(btn => {
    btn.classList.toggle('active', btn.dataset.origin === origin);
  });

  // Update URL
  const url = new URL(window.location.href);
  if (origin === 'all') {
    url.searchParams.delete('origin');
  } else {
    url.searchParams.set('origin', origin);
  }
  window.history.pushState({}, '', url.toString());

  // Dispatch event so InterestTagPanel + ArticleSearch handle cross-page rendering
  document.dispatchEvent(new CustomEvent('source-filter-changed', { detail: { origin } }));
}

function updateCounts(detail: { all?: number; submitted?: number; feed?: number; reset?: boolean }) {
  const buttons = document.querySelectorAll<HTMLElement>('[data-testid="source-filter"] .source-filter-btn');
  buttons.forEach((btn) => {
    const origin = btn.dataset.origin || 'all';
    const span = btn.querySelector<HTMLElement>('.source-count');
    if (!span) return;
    if (detail.reset) {
      span.textContent = btn.dataset.originalCount || '0';
    } else if (typeof detail[origin as 'all' | 'submitted' | 'feed'] === 'number') {
      span.textContent = String(detail[origin as 'all' | 'submitted' | 'feed']);
    }
  });
}

function initSourceFilter() {
  const buttons = document.querySelectorAll<HTMLElement>('[data-testid="source-filter"] .source-filter-btn');
  const validOrigins = new Set(Array.from(buttons).map(b => b.dataset.origin));

  // Server-side counts (passed as props) reflect the total across all pages.
  // Do NOT recalculate from rendered cards — that only counts the current page.

  // Per-button click listeners: bind exactly once per element.
  // View Transitions persist DOM and may re-fire astro:page-load on the same buttons.
  buttons.forEach(btn => {
    if (btn.dataset.sfBound === 'true') return;
    btn.dataset.sfBound = 'true';
    btn.addEventListener('click', () => {
      filterByOrigin(btn.dataset.origin || 'all');
    });
  });

  // Document-level listener: bind exactly once per page.
  const w = window as any;
  if (!w.__sourceFilterDocBound) {
    w.__sourceFilterDocBound = true;
    document.addEventListener('source-counts-update', ((e: CustomEvent) => {
      updateCounts(e.detail || {});
    }) as EventListener);
  }

  const originParam = new URLSearchParams(window.location.search).get('origin');
  if (originParam && validOrigins.has(originParam)) {
    filterByOrigin(originParam);
  }
}

document.addEventListener('astro:page-load', initSourceFilter);
</script>

<style>
.source-filter {
  display: flex;
  gap: var(--space-xs);
  margin-bottom: var(--space-lg);
}
.source-filter-btn {
  display: inline-flex;
  align-items: center;
  gap: var(--space-xs);
  padding: var(--space-sm) var(--space-md);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-sm);
  background: var(--color-bg);
  color: var(--color-text-muted);
  font-family: inherit;
  font-size: 0.875rem;
  font-weight: 500;
  cursor: pointer;
  transition: background 0.15s, color 0.15s, border-color 0.15s;
}
.source-filter-btn:hover {
  border-color: var(--color-primary);
  color: var(--color-text);
}
.source-filter-btn.active {
  background: var(--color-primary);
  color: white;
  border-color: var(--color-primary);
}
.source-count {
  font-size: 0.75rem;
  opacity: 0.8;
}
.source-filter-btn.active .source-count {
  opacity: 1;
}
.source-filter-empty {
  text-align: center;
  padding: var(--space-xl);
  color: var(--color-text-muted);
  font-size: 0.875rem;
}
</style>
