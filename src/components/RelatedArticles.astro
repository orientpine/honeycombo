---
import { getCollection } from 'astro:content';

interface Props {
  currentId: string;
  tags: string[];
  maxItems?: number;
}
const { currentId, tags, maxItems = 3 } = Astro.props;

const allCurated = await getCollection('curated', e => e.data.status === 'approved' && e.id !== currentId);
const related = allCurated
  .filter(e => e.data.tags.some(t => tags.includes(t)))
  .slice(0, maxItems);
---

{related.length > 0 && (
  <section class="related-articles" data-testid="related-articles">
    <h2 class="related-title">관련 기사</h2>
    <ul class="related-list">
      {related.map(article => (
        <li>
          <a href={`/articles/${article.id}`} class="related-link">
            <span class="related-article-title">{article.data.title}</span>
            <span class="related-source">{article.data.source}</span>
          </a>
        </li>
      ))}
    </ul>
  </section>
)}

<style>
.related-articles { margin-top: var(--space-2xl); padding-top: var(--space-xl); border-top: 1px solid var(--color-border); }
.related-title { font-size: 1.25rem; font-weight: 700; margin-bottom: var(--space-md); }
.related-list { list-style: none; display: flex; flex-direction: column; gap: var(--space-sm); }
.related-link { display: flex; justify-content: space-between; align-items: center; padding: var(--space-sm); border: 1px solid var(--color-border); border-radius: var(--radius-sm); text-decoration: none; color: var(--color-text); transition: border-color 0.15s; }
.related-link:hover { border-color: var(--color-primary); color: var(--color-primary); text-decoration: none; }
.related-article-title { font-weight: 500; }
.related-source { font-size: 0.8rem; color: var(--color-text-muted); }
</style>