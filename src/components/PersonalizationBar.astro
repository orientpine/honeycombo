---
interface Props {
  availableTags: string[];
}
const { availableTags } = Astro.props;
---

<div class="personalization-bar" data-testid="personalization-bar">
  <div class="personalization-header">
    <span class="personalization-label">⭐ 관심사 설정</span>
    <button class="personalization-toggle" id="personalization-toggle" aria-expanded="false">
      설정 열기 ▼
    </button>
  </div>
  
  <div class="personalization-panel" id="personalization-panel" hidden>
    <p class="personalization-hint">관심 있는 태그를 선택하면 해당 기사가 상단에 표시됩니다.</p>
    <div class="personalization-tags" id="personalization-tags">
      {availableTags.map(tag => (
        <button class="tag personalization-tag" data-tag={tag} onclick={`toggleInterest('${tag}')`}>
          {tag}
        </button>
      ))}
    </div>
    <button class="personalization-clear" onclick="clearInterests()">초기화</button>
  </div>
</div>

<script>
const STORAGE_KEY = 'honeycombo_interests';

function getInterests(): string[] {
  try {
    return JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]');
  } catch {
    return [];
  }
}

function saveInterests(interests: string[]): void {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(interests));
}

function toggleInterest(tag: string): void {
  const interests = getInterests();
  const idx = interests.indexOf(tag);
  if (idx === -1) {
    interests.push(tag);
  } else {
    interests.splice(idx, 1);
  }
  saveInterests(interests);
  updateUI();
  prioritizeArticles();
}

function clearInterests(): void {
  saveInterests([]);
  updateUI();
  prioritizeArticles();
}

function updateUI(): void {
  const interests = getInterests();
  const tags = document.querySelectorAll<HTMLElement>('.personalization-tag');
  tags.forEach(btn => {
    const tag = btn.dataset.tag || '';
    btn.classList.toggle('active', interests.includes(tag));
  });
  
  const label = document.querySelector('.personalization-label');
  if (label) {
    label.textContent = interests.length > 0
      ? `⭐ 관심사 (${interests.length}개 선택됨)`
      : '⭐ 관심사 설정';
  }
}

function prioritizeArticles(): void {
  const interests = getInterests();
  const list = document.querySelector('[data-testid="article-list"]');
  if (!list || interests.length === 0) return;
  
  const cards = Array.from(list.querySelectorAll<HTMLElement>('[data-testid="article-card"]'));
  const matched: HTMLElement[] = [];
  const unmatched: HTMLElement[] = [];
  
  cards.forEach(card => {
    const tags = (card.dataset.tags || '').split(',');
    const isMatch = interests.some(i => tags.includes(i));
    if (isMatch) {
      matched.push(card);
      card.classList.add('interest-match');
    } else {
      unmatched.push(card);
      card.classList.remove('interest-match');
    }
  });
  
  // Re-order: matched first
  [...matched, ...unmatched].forEach(card => list.appendChild(card));
}

// Toggle panel
document.getElementById('personalization-toggle')?.addEventListener('click', () => {
  const panel = document.getElementById('personalization-panel');
  const toggle = document.getElementById('personalization-toggle');
  if (panel && toggle) {
    const isHidden = panel.hidden;
    panel.hidden = !isHidden;
    toggle.setAttribute('aria-expanded', String(isHidden));
    toggle.textContent = isHidden ? '설정 닫기 ▲' : '설정 열기 ▼';
  }
});

// Initialize on load
document.addEventListener('DOMContentLoaded', () => {
  updateUI();
  prioritizeArticles();
});
</script>

<style>
.personalization-bar {
  background: var(--color-bg-secondary);
  border: 1px solid var(--color-border);
  border-radius: var(--radius-md);
  padding: var(--space-md);
  margin-bottom: var(--space-lg);
}
.personalization-header { display: flex; justify-content: space-between; align-items: center; }
.personalization-label { font-size: 0.9rem; font-weight: 600; }
.personalization-toggle {
  font-size: 0.8rem; color: var(--color-primary); background: none; border: none;
  cursor: pointer; font-family: inherit; padding: var(--space-xs) var(--space-sm);
}
.personalization-toggle:hover { text-decoration: underline; }
.personalization-panel { margin-top: var(--space-md); }
.personalization-hint { font-size: 0.8rem; color: var(--color-text-muted); margin-bottom: var(--space-sm); }
.personalization-tags { display: flex; flex-wrap: wrap; gap: var(--space-xs); margin-bottom: var(--space-sm); }
.personalization-tag { cursor: pointer; border: none; font-family: inherit; }
.personalization-clear {
  font-size: 0.8rem; color: var(--color-text-muted); background: none; border: none;
  cursor: pointer; font-family: inherit; text-decoration: underline;
}
.interest-match { border-color: var(--color-accent) !important; }
</style>
