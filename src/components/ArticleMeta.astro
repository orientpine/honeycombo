---
interface Props {
  source: string;
  date: Date | string;
  tags: string[];
}
const { source, date, tags } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<div class="article-meta-block" data-testid="article-meta">
  <div class="meta-row">
    <span class="badge">{source}</span>
    <time datetime={new Date(date).toISOString()}>{formattedDate}</time>
  </div>
  <div class="meta-tags">
    {tags.map(tag => <span class="tag">{tag}</span>)}
  </div>
</div>

<style>
.article-meta-block { display: flex; flex-direction: column; gap: var(--space-sm); margin-bottom: var(--space-lg); }
.meta-row { display: flex; align-items: center; gap: var(--space-sm); flex-wrap: wrap; }
.meta-row time { color: var(--color-text-muted); font-size: 0.875rem; }
.meta-tags { display: flex; flex-wrap: wrap; gap: var(--space-xs); }
</style>