<!-- Visible interest-match highlight for ArticleCard.
     Global because ArticleCard already declares its scoped styles separately. -->
<style is:global>
  .article-card.interest-match {
    border-color: var(--color-accent) !important;
    background: linear-gradient(
      135deg,
      var(--color-bg) 0%,
      rgba(252, 185, 36, 0.08) 100%
    );
    box-shadow: 0 0 0 1px var(--color-accent), 0 2px 8px rgba(252, 185, 36, 0.15);
    position: relative;
  }
  /*
   * Interest-match badge — floating notification bubble OUTSIDE the card boundary,
   * never affecting internal layout.
   *
   * Why outside the card?
   *   The card's `.article-meta` row contains badges + date with `margin-left: auto`.
   *   Putting the badge inside (whether as a flex item or with internal padding)
   *   either pushes content (causing wrap on YouTube cards) or shrinks usable
   *   width (causing wrap on plain cards too — measured 53.66px / 2 lines).
   *   By positioning the badge at `top: -8px; left: -8px` it overhangs the card
   *   like a notification dot — ZERO impact on internal layout regardless of
   *   thumbnail/badge variants. Card has `position: relative` already, so this
   *   anchors correctly.
   *
   * Outer ring (white box-shadow) crisply separates the badge from the page
   * background, matching the modern Apple-style theme of the rest of the panel.
   */
  .article-card.interest-match::before {
    content: '⭐';
    position: absolute;
    top: -8px;
    left: -8px;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    background: linear-gradient(135deg, var(--color-accent) 0%, #FFA000 100%);
    color: #FFFFFF;
    border-radius: 999px;
    font-size: 0.85rem;
    line-height: 1;
    box-shadow:
      0 0 0 2px var(--color-bg, #FFFFFF),
      0 2px 8px rgba(252, 185, 36, 0.5);
    pointer-events: none;
    transition: transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .article-card.interest-match:hover::before {
    transform: scale(1.1);
  }

  /* Honor user's reduced-motion preference for the badge hover. */
  @media (prefers-reduced-motion: reduce) {
    .article-card.interest-match::before {
      transition: none;
    }
    .article-card.interest-match:hover::before {
      transform: none;
    }
  }

  /* ----------------------------------------------------------------------
   * Filtered results header + container.
   *
   * Lives in the global block because `.itp-filtered-results` is rendered as
   * a sibling of `.interest-tag-panel` (see markup near line 154), so the
   * panel's scoped `:global()` selectors can't reach it.
   *
   * Layout philosophy:
   *   - Generous breathing room above (--space-2xl) separates the panel from
   *     the result section so the cards feel like their own surface, not glued
   *     to the filter UI.
