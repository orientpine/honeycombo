---
interface Props {
  tags: string[];
}
const { tags } = Astro.props;
---

<div class="tag-filter" data-testid="tag-filter">
  <span class="tag-filter-label">태그 필터:</span>
  <button class="tag active" data-tag="all">전체</button>
  {tags.map(tag => (
    <button class="tag" data-tag={tag}>{tag}</button>
  ))}
</div>

<script>
function filterByTag(tag: string) {
  const cards = document.querySelectorAll('[data-testid="article-card"]');
  const buttons = document.querySelectorAll('[data-testid="tag-filter"] .tag');

  buttons.forEach(btn => {
    btn.classList.toggle('active', (btn as HTMLElement).dataset.tag === tag);
  });

  cards.forEach(card => {
    const cardTags = (card as HTMLElement).dataset.tags?.split(',') || [];
    const show = tag === 'all' || cardTags.includes(tag);
    (card as HTMLElement).style.display = show ? '' : 'none';
  });

  const url = new URL(window.location.href);
  if (tag === 'all') {
    url.searchParams.delete('tag');
  } else {
    url.searchParams.set('tag', tag);
  }
  window.history.pushState({}, '', url.toString());
}

function initTagFilter() {
  const allButtons = document.querySelectorAll<HTMLElement>('[data-testid="tag-filter"] .tag');
  const validTags = new Set(Array.from(allButtons).map(b => b.dataset.tag));

  allButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      filterByTag(btn.dataset.tag || 'all');
    });
  });

  const tagParam = new URLSearchParams(window.location.search).get('tag');
  if (tagParam && validTags.has(tagParam)) {
    filterByTag(tagParam);
  } else if (tagParam) {
    // Unknown tag param — fall back to showing all
    filterByTag('all');
  }
}

if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initTagFilter);
} else {
  initTagFilter();
}
</script>

<style>
.tag-filter { display: flex; flex-wrap: wrap; gap: var(--space-xs); align-items: center; margin-bottom: var(--space-lg); }
.tag-filter-label { font-size: 0.875rem; color: var(--color-text-muted); margin-right: var(--space-xs); }
.tag-filter .tag { cursor: pointer; border: none; font-family: inherit; font-size: 0.75rem; }
</style>