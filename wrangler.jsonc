{
	"compatibility_date": "2026-04-11",
	"compatibility_flags": ["global_fetch_strictly_public"],
	"name": "honeycombo",
	"main": "@astrojs/cloudflare/entrypoints/server",
	"assets": {
		"directory": "./dist",
		"binding": "ASSETS"
	},
	"observability": {
		"enabled": true
	},
	"d1_databases": [
		{
			"binding": "DB",
			"database_name": "honeycombo-db",
			"database_id": "<placeholder>",
			"migrations_dir": "migrations"
		}
	]
}