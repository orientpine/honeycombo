{
  "name": "honeycombo",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "prebuild": "rm -f node_modules/.astro/data-store.json",
    "build": "astro build",
    "preview": "bun run build && wrangler pages dev dist",
    "check": "astro check",
    "validate": "bun run scripts/validate.ts",
    "backfill:submissions": "bun run scripts/backfill-submissions.ts",
    "test": "vitest run",
    "generate-types": "wrangler types",
    "deploy": "bun run build && wrangler pages deploy dist",
    "summarize": "bun run scripts/summarize-articles.ts",
    "validate:docs": "bun run scripts/validate-docs.ts"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.8",
    "@types/bun": "latest",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.1"
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.2",
    "@google/generative-ai": "^0.24.1",
    "@mozilla/readability": "^0.6.0",
    "astro": "^6.1.5",
    "linkedom": "^0.18.12",
    "rss-parser": "^3.13.0",
    "nanoid": "^5.1.5"
  },
  "overrides": {
    "vite": "^7"
  }
}
